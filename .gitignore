# Core build & publish outputs
[Bb]in/
[Oo]bj/
[Ww]in32/
[Xx]64/
[Xx]86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Pp]ublish/
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Visual Studio files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.suo.tmp
*.cache
*.dbmdl
*.opendb
*.bak

# JetBrains Rider & IntelliJ files
.idea/
*.sln.iml

# VS Code files
.vscode/

# NuGet Packages
packages/
project.lock.json
project.assets.json

# Local Databases, Logs, Backups, and Reports
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
*.log
[Ll]ogs/
[Bb]ackups/
[Rr]eports/
[Ii]nvoices/
InternalTrace*.log

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db

# Python scripts output & virtual envs
__pycache__/
*.pyc
*.pyo
.venv/
env/
venv/
ENV/

# Application output PDFs
[Ss]ample\ reports/001.pdf
[Ss]ample\ reports/2-.pdf

# Local configurations and secret templates
appsettings.json
appsettings.*.json
!appsettings.example.json

# Tools and debug artifacts
tools/
*.exe
*.dll.bak
*.pdb

# Local project notes / temp files
initial_prompt.txt
Project-Progress.txt
Step-by-Step Implementatio.txt
