<UserControl x:Class="LabSystem.UI.Controls.SidebarNavigation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="220">

    <Border x:Name="SidebarBorder"
            Width="60"
            Background="{StaticResource SidebarGradientBrush}"
            BorderThickness="0"
            ClipToBounds="True"
            MouseEnter="SidebarBorder_MouseEnter"
            MouseLeave="SidebarBorder_MouseLeave">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Brand / Logo & Pin -->
            <Grid Grid.Row="0" Margin="0 20 0 20" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Grid.Column="0"
                                         Kind="Microscope"
                                         Width="32" Height="32"
                                         Foreground="{StaticResource SidebarIconBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="QDC SYSTEM"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{StaticResource SidebarTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0 0 8 0" />
                <Button Grid.Column="2"
                        Click="PinButton_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="4"
                        Width="36" Height="36"
                        Foreground="{StaticResource SidebarTextBrush}"
                        Margin="0 0 10 0"
                        VerticalAlignment="Center">
                    <materialDesign:PackIcon Width="18" Height="18">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Kind" Value="PinOutline" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsSidebarPinned}" Value="True">
                                        <Setter Property="Kind" Value="Pin" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                </Button>
            </Grid>

            <!-- Navigation ListBox -->
            <ListBox Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectedIndex="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=SelectedIndex, Mode=TwoWay}"
                     ItemContainerStyle="{StaticResource SidebarItemStyle}">

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="Home" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Overview" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="AccountGroup" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Patients" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="ClipboardText" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="New Order" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="TestTube" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Work Queue" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="FileDocumentOutline" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Report Gen" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Billing" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="Database" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Test Catalog" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="Account" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Doctors" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>

                <ListBoxItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="Cog" Width="20" Height="20"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Foreground="{StaticResource SidebarIconBrush}" />
                        <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0" />
                    </Grid>
                </ListBoxItem>
            </ListBox>

            <!-- Sidebar Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource SidebarFooterBrush}"
                    Padding="0 14"
                    BorderBrush="{StaticResource SidebarDividerBrush}"
                    BorderThickness="0 1 0 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="AccountCircle" Width="24" Height="24"
                                             Foreground="{StaticResource SidebarIconBrush}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Margin="8 0 0 0" VerticalAlignment="Center">
                        <TextBlock Text="Lab Technician" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Single Operator Mode" Foreground="{StaticResource SidebarTextBrush}" FontSize="10" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>

</UserControl>
