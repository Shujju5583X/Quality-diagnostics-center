<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════
         QUALITY DIAGNOSTICS CENTER – App Styles
         Professional Medical Teal/Blue Theme
         ════════════════════════════════════════════════════════════════ -->

    <!-- ─── Primary Teal Palette ─── -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#00897B" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#004D40" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#B2DFDB" />
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#E0F2F1" />

    <!-- ─── Accent Cyan Palette ─── -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#00ACC1" />
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="#00838F" />
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="#B2EBF2" />

    <!-- ─── Sidebar ─── -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0D2137" />
    <SolidColorBrush x:Key="SidebarIconBrush" Color="#80CBC4" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#B2DFDB" />
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#26A69A" />
    <SolidColorBrush x:Key="SidebarFooterBrush" Color="#071524" />
    <SolidColorBrush x:Key="SidebarDividerBrush" Color="#1A3352" />

    <!-- ─── Content Area ─── -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F4F6F8" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#E0E0E0" />

    <!-- ─── Status Colors ─── -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#2E7D32" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#E8F5E9" />
    <SolidColorBrush x:Key="WarningBrush" Color="#E65100" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="#FFF3E0" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#C62828" />
    <SolidColorBrush x:Key="ErrorLightBrush" Color="#FFEBEE" />
    <SolidColorBrush x:Key="InfoBrush" Color="#0277BD" />
    <SolidColorBrush x:Key="InfoLightBrush" Color="#E1F5FE" />

    <!-- ─── Text ─── -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#212121" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#757575" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#BDBDBD" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextLinkBrush" Color="#00897B" />

    <!-- ─── DataGrid ─── -->
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#00897B" />
    <SolidColorBrush x:Key="DataGridHeaderForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="DataGridAlternatingRowBrush" Color="#F8FAFB" />
    <SolidColorBrush x:Key="DataGridHoverBrush" Color="#E0F2F1" />
    <SolidColorBrush x:Key="DataGridSelectedBrush" Color="#B2DFDB" />
    <SolidColorBrush x:Key="DataGridBorderBrush" Color="#E0E0E0" />

    <!-- ─── Gradient Brushes ─── -->
    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00897B" Offset="0.0" />
        <GradientStop Color="#00ACC1" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D2137" Offset="0.0" />
        <GradientStop Color="#0A1A2E" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>
