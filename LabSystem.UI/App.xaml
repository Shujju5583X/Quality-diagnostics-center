<Application x:Class="LabSystem.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:LabSystem.UI.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design Theme -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <!-- Custom App Styles -->
                <ResourceDictionary Source="/Resources/AppStyles.xaml" />
                <ResourceDictionary Source="/Resources/CardStyles.xaml" />
                <ResourceDictionary Source="/Resources/SidebarStyles.xaml" />
                <ResourceDictionary Source="/Resources/DataGridStyles.xaml" />
                <ResourceDictionary Source="/Resources/ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
             <BooleanToVisibilityConverter x:Key="BoolToVis" />
             <converters:StringVisibilityConverter x:Key="StringVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
