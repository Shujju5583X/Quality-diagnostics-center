<Window x:Class="LabSystem.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:LabSystem.UI.ViewModels"
        xmlns:views="clr-namespace:LabSystem.UI.Views"
        mc:Ignorable="d"
        Title="Quality Diagnostic Center" Height="768" Width="1200" Icon="logo.png"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Margin="16 0 0 0" VerticalAlignment="Center">
                    <Image Source="logo.png" Width="28" Height="28" Margin="0 0 8 0" VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource MaterialDesignHeadline6TextBlock}">Quality Diagnostic Center</TextBlock>
                </StackPanel>
                <Button Command="{Binding BackupCommand}" HorizontalAlignment="Right" DockPanel.Dock="Right" Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DatabaseSync" Margin="0 0 8 0" VerticalAlignment="Center" />
                        <TextBlock Text="BACKUP NOW" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>
        </materialDesign:ColorZone>

        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <!-- Template for LoginView -->
                <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
                    <!-- Basic Login View Embedded for simplicity -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
                        <materialDesign:Card Padding="40" Margin="16" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp4">
                            <StackPanel>
                                <Border CornerRadius="8" ClipToBounds="True" HorizontalAlignment="Center" Margin="0 0 0 16" Width="80" Height="80">
                                    <Image Source="logo.png" Stretch="Uniform" />
                                </Border>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" HorizontalAlignment="Center" Margin="0 0 0 24">Staff Login</TextBlock>
                                <PasswordBox materialDesign:HintAssist.Hint="Enter PIN (e.g. 1234)" 
                                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                             PasswordChanged="PinBox_PasswordChanged"
                                             Margin="0 0 0 24" />
                                <TextBlock Foreground="Red" Text="{Binding ErrorMessage}" HorizontalAlignment="Center" Margin="0 0 0 16" />
                                <Button Command="{Binding LoginCommand}" Content="LOGIN" Style="{StaticResource MaterialDesignRaisedButton}" Height="40" />
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </DataTemplate>

                <!-- Template for DashboardView -->
                <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                    <views:DashboardView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
