<Window x:Class="LabSystem.UI.Views.PatientHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Patient History" Width="900" Height="500" WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding PatientName, StringFormat='Patient History: {0}'}" 
                   FontWeight="Bold" FontSize="18" Margin="0 0 0 8" Foreground="#311B92"/>

        <TextBlock Grid.Row="1" Text="{Binding HistoryCount, StringFormat='{}{0} records found'}" 
                   Foreground="Gray" FontSize="12" Margin="0 0 0 8"/>

        <DataGrid Grid.Row="2" ItemsSource="{Binding PatientHistory}" AutoGenerateColumns="False"
                  IsReadOnly="True" AlternatingRowBackground="#FAF9FC"
                  EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
                <DataGridTextColumn Header="Test Name" Binding="{Binding TestName}" Width="*"/>
                <DataGridTextColumn Header="Value" Binding="{Binding ValueText}" Width="80"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70"/>
                <DataGridTemplateColumn Header="Status" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Normal"/>
                                        <Setter Property="Foreground" Value="#00796B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                                                <Setter Property="Text" Value="ABNORMAL"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ref Low" Binding="{Binding ReferenceLow, StringFormat='{}{0:N1}'}" Width="70"/>
                <DataGridTextColumn Header="Ref High" Binding="{Binding ReferenceHigh, StringFormat='{}{0:N1}'}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="CLOSE" Click="CloseButton_Click" Width="100" Height="32" HorizontalAlignment="Right" Margin="0 8 0 0"
                Style="{StaticResource MaterialDesignFlatButton}"/>
    </Grid>
</Window>
