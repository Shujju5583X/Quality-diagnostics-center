<UserControl x:Class="LabSystem.UI.Views.Dashboard.ReportGenerationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" />
            <ColumnDefinition Width="3.5*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Complete Orders list -->
        <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="Completed Orders" />

                <TextBox Grid.Row="1"
                         materialDesign:HintAssist.Hint="Search by patient name, order ID..."
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0 0 0 16"
                         Text="{Binding ReportSearchQuery, UpdateSourceTrigger=PropertyChanged}" />

                <DataGrid Grid.Row="2"
                          x:Name="CompletedOrdersGrid"
                          ItemsSource="{Binding CompleteOrders}"
                          SelectedItem="{Binding SelectedReportOrder, Mode=TwoWay}"
                          SelectionChanged="CompletedOrdersGrid_SelectionChanged"
                          Style="{StaticResource TealDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                        <DataGridTextColumn Header="Patient Name" Binding="{Binding Patient.FullName}" Width="*" />
                        <DataGridTextColumn Header="Completed At" Binding="{Binding UpdatedAt, StringFormat={}{0:dd MMM HH:mm}}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Right Panel: Report Preview & Generation -->
        <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="Report Preview" />

                <Grid Grid.Row="1" Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              x:Name="ReportLetterheadComboBox"
                              materialDesign:HintAssist.Hint="Letterhead Option"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              SelectionChanged="ReportLetterheadComboBox_SelectionChanged"
                              Margin="0 0 12 0" SelectedIndex="0">
                        <ComboBoxItem Content="With Letterhead" />
                        <ComboBoxItem Content="Without Letterhead" />
                    </ComboBox>
                    <Button Grid.Column="1" Click="SaveReportPdf_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Margin="0 0 8 0" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 4 0" VerticalAlignment="Center" Width="16" Height="16" />
                            <TextBlock Text="SAVE PDF" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Click="PrintReportPdf_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="36" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Printer" Margin="0 0 4 0" VerticalAlignment="Center" Width="16" Height="16" />
                            <TextBlock Text="PRINT" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="2" BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <WebBrowser x:Name="ReportWebViewer" Margin="4" />
                </Border>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
