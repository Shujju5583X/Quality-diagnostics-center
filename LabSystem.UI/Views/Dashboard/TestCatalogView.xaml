<UserControl x:Class="LabSystem.UI.Views.Dashboard.TestCatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <TabControl BorderThickness="0" Background="Transparent">
            <TabControl.Resources>
                <!-- TabItem Style (Customized for Modern/Material look) -->
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="20 12" />
                    <Setter Property="Header" Value="{Binding Header, RelativeSource={RelativeSource Self}}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0 0 0 3"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#1000897B" />
                                        <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: TESTS & DEPARTMENTS -->
            <TabItem Header="TESTS &amp; DEPARTMENTS">
                <Grid Margin="0 16 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Departments List -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 8 0" Padding="16" Style="{StaticResource ContentCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0 0 0 12">
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Departments" Margin="0" />
                                <TextBlock Text="Select a department to filter tests" Style="{StaticResource MaterialDesignCaptionTextBlock}" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <!-- Department List -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" Margin="0 0 0 16"
                                     Style="{StaticResource MaterialDesignListBox}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4">
                                            <materialDesign:PackIcon Kind="FolderOutline" Width="18" Height="18" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" Margin="0 0 8 0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Add / Edit Department section -->
                            <Border Grid.Row="2" Background="{StaticResource ContentBackgroundBrush}" Margin="-16" Padding="16">
                                <StackPanel>
                                    <TextBox materialDesign:HintAssist.Hint="New/Rename Department"
                                             Text="{Binding NewDepartmentName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding AddDepartmentCommand}" Content="ADD"
                                                Style="{StaticResource PrimaryButtonStyle}" Height="32" Margin="0 0 2 0" FontSize="10" />
                                        <Button Grid.Column="1" Command="{Binding RenameDepartmentCommand}" Content="RENAME"
                                                Style="{StaticResource OutlinedButtonStyle}" Height="32" Margin="2 0 2 0" FontSize="10" />
                                        <Button Grid.Column="2" Command="{Binding DeleteDepartmentCommand}" Content="DELETE"
                                                Style="{StaticResource DangerButtonStyle}" Height="32" Margin="2 0 0 0" FontSize="10" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Center Column: Tests List Grid -->
                    <materialDesign:Card Grid.Column="1" Margin="8 0 8 0" Padding="16" Style="{StaticResource ContentCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0 0 0 8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SectionHeaderStyle}" Text="Available Tests" VerticalAlignment="Center" Margin="0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Items.Count, ElementName=CatalogGrid, StringFormat='{}Total: {0} Tests'}" Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0 0 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Row="1"
                                         x:Name="CatalogSearchBox"
                                         materialDesign:HintAssist.Hint="Search by test name, category or group..."
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0 0 0 16"
                                         TextChanged="CatalogSearchBox_TextChanged" />
                            </Grid>

                            <DataGrid Grid.Row="2"
                                      x:Name="CatalogGrid"
                                      ItemsSource="{Binding CatalogTestTypes}"
                                      SelectedItem="{Binding SelectedCatalogTest}"
                                      Style="{StaticResource TealDataGridStyle}"
                                      IsReadOnly="True"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Test Name" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='₹{0:N2}'}" Width="1*" />
                                    <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="1.5*" />
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="0.8*" />
                                    <DataGridTemplateColumn Header="Status" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="StatusBorder" CornerRadius="4" Padding="6 2" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FFEBEE">
                                                    <TextBlock x:Name="StatusText" Text="Inactive" Foreground="#C62828" FontSize="10" FontWeight="Bold" />
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter TargetName="StatusBorder" Property="Background" Value="#E8F5E9" />
                                                        <Setter TargetName="StatusText" Property="Text" Value="Active" />
                                                        <Setter TargetName="StatusText" Property="Foreground" Value="#2E7D32" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right Column: Test Form -->
                    <materialDesign:Card Grid.Column="2" Margin="8 0 0 0" Padding="16" Style="{StaticResource ContentCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="0 0 0 8" Margin="0 0 0 12">
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{Binding CatalogFormTitle}" VerticalAlignment="Center" Margin="0" />
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="2 0">
                                    <TextBox materialDesign:HintAssist.Hint="Test Name *"
                                             Text="{Binding CatalogTestName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                    <TextBox materialDesign:HintAssist.Hint="Price (₹) *"
                                             Text="{Binding CatalogTestPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  materialDesign:HintAssist.Hint="Department *"
                                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                  ItemsSource="{Binding Departments}"
                                                  SelectedItem="{Binding CatalogTestDepartment}"
                                                  DisplayMemberPath="Name"
                                                  Margin="0 0 6 0" />
                                        <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Group Name"
                                                 Text="{Binding CatalogTestGroupName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="6 0 0 0" />
                                    </Grid>

                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Unit"
                                                 Text="{Binding CatalogTestUnit, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 6 0" />
                                        <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Sort Order"
                                                 Text="{Binding CatalogTestSortOrder, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="6 0 0 0" />
                                    </Grid>

                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Ref Range Low"
                                                 Text="{Binding CatalogTestLow, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 6 0" />
                                        <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Ref Range High"
                                                 Text="{Binding CatalogTestHigh, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="6 0 0 0" />
                                    </Grid>

                                    <TextBox materialDesign:HintAssist.Hint="Method (e.g. ELISA)"
                                             Text="{Binding CatalogTestMethod, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                    <TextBox materialDesign:HintAssist.Hint="Interpretation Notes"
                                             Text="{Binding CatalogTestInterpretation, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0 0 0 16" />

                                    <CheckBox Content="Is Active Test" IsChecked="{Binding CatalogTestIsActive}" Margin="0 0 0 20" />

                                    <!-- If editing, show SAVE, CANCEL, DEL -->
                                    <Grid Visibility="{Binding IsEditingCatalogTest, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding SaveCatalogTestCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" Margin="0 0 2 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="SAVE" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding ClearCatalogFormCommand}"
                                                Style="{StaticResource OutlinedButtonStyle}" Margin="2 0 2 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Cancel" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="CANCEL" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" Command="{Binding DeleteCatalogTestCommand}"
                                                Style="{StaticResource DangerButtonStyle}" Margin="2 0 0 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Delete" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="DELETE" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    
                                    <!-- If adding, show ADD and CLEAR -->
                                    <Grid Visibility="{Binding IsNotEditingCatalogTest, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding AddCatalogTestCommand}"
                                                Style="{StaticResource AccentButtonStyle}" Margin="0 0 4 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Plus" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="ADD NEW" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding ClearCatalogFormCommand}"
                                                Style="{StaticResource OutlinedButtonStyle}" Margin="4 0 0 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Eraser" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="CLEAR" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- TAB 2: PACKAGES & PANELS -->
            <TabItem Header="PACKAGES &amp; PANELS">
                <Grid Margin="0 16 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="400" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Panel List -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 8 0" Padding="16" Style="{StaticResource ContentCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="Test Packages &amp; Panels" Margin="0 0 0 12" />

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding TestPanelsCatalog}"
                                      SelectedItem="{Binding SelectedTestPanel}"
                                      Style="{StaticResource TealDataGridStyle}"
                                      IsReadOnly="True"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding PanelId}" Width="Auto" />
                                    <DataGridTextColumn Header="Package Name" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*" />
                                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='₹{0:N2}'}" Width="1*" />
                                    <DataGridTextColumn Header="Tests" Binding="{Binding TestTypes.Count}" Width="Auto" />
                                    <DataGridTemplateColumn Header="Action" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Command="{Binding DataContext.EditTestPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                            Padding="4" Height="24" Width="24" ToolTip="Edit">
                                                        <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" />
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right: Panel Form -->
                    <materialDesign:Card Grid.Column="1" Margin="8 0 0 0" Padding="16" Style="{StaticResource ContentCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="0 0 0 8" Margin="0 0 0 12">
                                <TextBlock VerticalAlignment="Center" Margin="0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHeaderStyle}">
                                            <Setter Property="Text" Value="Add New Package" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingTestPanel}" Value="True">
                                                    <Setter Property="Text" Value="Edit Package" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="2 0">
                                    <TextBox materialDesign:HintAssist.Hint="Package Name *"
                                             Text="{Binding NewTestPanelName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                    <TextBox materialDesign:HintAssist.Hint="Description"
                                             Text="{Binding NewTestPanelDescription, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                    <TextBox materialDesign:HintAssist.Hint="Price (₹) *"
                                             Text="{Binding NewTestPanelPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 20" />

                                    <TextBlock Text="Select Tests for Package:" FontWeight="SemiBold" Margin="0 8 0 4"/>
                                    
                                    <Border BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" CornerRadius="4" Margin="0 0 0 20">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="250">
                                            <ItemsControl ItemsSource="{Binding PackageTestSelections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="8 4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Category}" Opacity="0.5" VerticalAlignment="Center" FontSize="11" Margin="8 0 0 0"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- If editing, show SAVE, CANCEL, DEL -->
                                    <Grid Visibility="{Binding IsEditingTestPanel, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding UpdateTestPanelCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" Margin="0 0 2 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="SAVE" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding ClearTestPanelFormCommand}"
                                                Style="{StaticResource OutlinedButtonStyle}" Margin="2 0 2 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Cancel" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="CANCEL" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" Command="{Binding DeleteTestPanelCommand}"
                                                Style="{StaticResource DangerButtonStyle}" Margin="2 0 0 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Delete" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="DELETE" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- If adding, show ADD and CLEAR -->
                                    <Grid Visibility="{Binding IsNotEditingTestPanel, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding AddTestPanelCommand}"
                                                Style="{StaticResource AccentButtonStyle}" Margin="0 0 4 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Plus" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="ADD NEW" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding ClearTestPanelFormCommand}"
                                                Style="{StaticResource OutlinedButtonStyle}" Margin="4 0 0 0" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Eraser" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14" />
                                                <TextBlock Text="CLEAR" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
