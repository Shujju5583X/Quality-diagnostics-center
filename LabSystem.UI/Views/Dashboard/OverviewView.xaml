<UserControl x:Class="LabSystem.UI.Views.Dashboard.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="System Overview" FontSize="20" />

        <!-- Stats Cards -->
        <Grid Grid.Row="1" Margin="0 0 0 24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Row 1: Lifetime cards (teal shades) -->
            <materialDesign:Card Grid.Column="0" Margin="4" Style="{StaticResource StatCardStyle}" Background="#E0F2F1">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32" Foreground="{StaticResource PrimaryDarkBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="TOTAL PATIENTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="{Binding TotalPatients}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" Margin="0 4 0 0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Margin="4" Style="{StaticResource StatCardStyle}" Background="{StaticResource WarningLightBrush}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Clock" Width="32" Height="32" Foreground="{StaticResource WarningBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="PENDING ORDERS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                    <TextBlock Text="{Binding PendingOrders}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0 4 0 0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Margin="4" Style="{StaticResource StatCardStyle}" Background="{StaticResource PrimaryBackgroundBrush}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="ClipboardCheck" Width="32" Height="32" Foreground="{StaticResource SuccessBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="COMPLETED" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                    <TextBlock Text="{Binding CompletedOrders}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" Margin="0 4 0 0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="3" Margin="4" Style="{StaticResource StatCardStyle}" Background="{StaticResource ErrorLightBrush}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AlertDecagram" Width="32" Height="32" Foreground="{StaticResource ErrorBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="ABNORMAL FLAGS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                    <TextBlock Text="{Binding AbnormalResultsFlagged}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" Margin="0 4 0 0" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Row 2: Today's cards (blue-cyan shades) -->
            <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="4" Style="{StaticResource StatCardStyle}" Background="#E1F5FE">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AccountOutline" Width="32" Height="32" Foreground="{StaticResource InfoBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="TODAY'S PATIENTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" />
                    <TextBlock Text="{Binding TodayPatients}" FontSize="36" FontWeight="Bold" Foreground="#01579B" Margin="0 4 0 0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Grid.Column="1" Margin="4" Style="{StaticResource StatCardStyle}" Background="{StaticResource SuccessLightBrush}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="FileDocument" Width="32" Height="32" Foreground="{StaticResource SuccessBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="TODAY'S ORDERS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                    <TextBlock Text="{Binding TodayOrders}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0 4 0 0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Grid.Column="2" Margin="4" Style="{StaticResource StatCardStyle}" Background="{StaticResource InfoLightBrush}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Cash" Width="32" Height="32" Foreground="{StaticResource InfoBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="TODAY'S REVENUE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" />
                    <TextBlock FontSize="36" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" Margin="0 4 0 0">
                        <TextBlock.Text>
                            <Binding Path="TodayRevenue" StringFormat="₹{0:N0}" />
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Grid.Column="3" Margin="4" Style="{StaticResource StatCardStyle}" Background="{StaticResource PrimaryBackgroundBrush}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Calendar" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}" Margin="0 0 0 8" />
                    <TextBlock Text="TODAY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="{Binding TodayOrders, StringFormat='{}{0} orders'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" Margin="0 4 0 0" />
                    <TextBlock FontSize="14" Foreground="{StaticResource PrimaryBrush}">
                        <TextBlock.Text>
                            <Binding Path="TodayPatients" StringFormat="{}{0} patients" />
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Recent Orders -->
        <materialDesign:Card Grid.Row="2" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="Recent Test Orders" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Orders}"
                          Style="{StaticResource TealDataGridStyle}"
                          MaxHeight="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                        <DataGridTextColumn Header="Patient Name" Binding="{Binding Patient.FullName}" Width="*" />
                        <DataGridTextColumn Header="Order Date" Binding="{Binding OrderedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="Auto" />
                        <DataGridTextColumn Header="Referred By" Binding="{Binding ReferredBy, TargetNullValue='SELF'}" Width="Auto" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
