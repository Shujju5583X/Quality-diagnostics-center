<UserControl x:Class="LabSystem.UI.Views.Dashboard.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:LabSystem.UI.Converters">
    <UserControl.Resources>
        <converters:DecimalToVisibilityConverter x:Key="DecimalToVis" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="Invoices" />
                <DataGrid Grid.Row="1"
                          x:Name="InvoicesGrid"
                          ItemsSource="{Binding Invoices}"
                          SelectedItem="{Binding SelectedInvoice}"
                          Style="{StaticResource TealDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Inv #" Binding="{Binding InvoiceId}" Width="Auto" />
                        <DataGridTextColumn Header="Patient" Binding="{Binding Order.Patient.FullName}" Width="*" />
                        <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}" Width="Auto" />
                        <DataGridTextColumn Header="Paid" Binding="{Binding AmountPaid, StringFormat='₹{0:N0}'}" Width="Auto" />
                        <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod, TargetNullValue='-'}" Width="Auto" />
                        <DataGridTemplateColumn Header="Status" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8 4" HorizontalAlignment="Center" Margin="0 2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="10" />
                                                <Setter Property="Padding" Value="8 4" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontWeight="SemiBold" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="FontSize" Value="11" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                            <Setter Property="Text" Value="Pending" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                            <Setter Property="Text" Value="Partial" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                            <Setter Property="Text" Value="Paid" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Invoice Detail Header -->
                <Border Grid.Row="0" Background="{StaticResource PrimaryBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="36" Height="36"
                                                 Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Margin="16 0 0 0">
                            <TextBlock Text="{Binding SelectedInvoice.Order.Patient.FullName, TargetNullValue='No Invoice Selected'}"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                <TextBlock Text="Invoice #" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedInvoice.InvoiceId, TargetNullValue='-'}"
                                           FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="12" Margin="0 0 16 0" />
                                <TextBlock Text="Subtotal: ₹" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedInvoice.TotalAmount, StringFormat='{}{0:N2}', TargetNullValue='-'}"
                                           FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0"
                                        Visibility="{Binding SelectedInvoice.DiscountAmount, Converter={StaticResource DecimalToVis}}">
                                <TextBlock Text="Discount: -₹" Foreground="{StaticResource ErrorBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedInvoice.DiscountAmount, StringFormat='{}{0:N2}'}"
                                           FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0"
                                        Visibility="{Binding SelectedInvoice.TaxAmount, Converter={StaticResource DecimalToVis}}">
                                <TextBlock Text="Tax: +₹" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedInvoice.TaxAmount, StringFormat='{}{0:N2}'}"
                                           FontWeight="Bold" Foreground="{StaticResource WarningBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                <TextBlock Text="Grand Total: ₹" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedInvoice.GrandTotal, StringFormat='{}{0:N2}', TargetNullValue='-'}"
                                           FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0"
                                        Visibility="{Binding SelectedInvoice.DueAmount, Converter={StaticResource DecimalToVis}}">
                                <TextBlock Text="Due Amount: ₹" Foreground="{StaticResource ErrorBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedInvoice.DueAmount, StringFormat='{}{0:N2}'}"
                                           FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1">
                    <!-- Discount/Tax Section -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="12" Margin="0 0 0 16">
                        <StackPanel>
                            <TextBlock Text="DISCOUNT &amp; TAX" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 0 8" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Discount (₹):" VerticalAlignment="Center" Width="80" FontSize="12" />
                                <TextBox Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" Margin="0 0 16 0"
                                         Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Amount" />
                                <TextBlock Text="Tax (₹):" VerticalAlignment="Center" Width="55" FontSize="12" />
                                <TextBox Text="{Binding TaxAmount, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" Margin="0 0 16 0"
                                         Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Amount" />
                                <Button Command="{Binding ApplyDiscountTaxCommand}" Content="APPLY"
                                        Style="{StaticResource OutlinedButtonStyle}" Height="32" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="PAYMENT ACTIONS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 0 8" />
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <TextBlock Text="Amount: ₹" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" />
                        <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Margin="8 0 0 0"
                                 Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Enter amount" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 16">
                        <Button Command="{Binding AddPaymentCashCommand}"
                                Style="{StaticResource OutlinedButtonStyle}" Height="50" Width="140" Margin="0 0 16 0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cash" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center" />
                                <TextBlock Text="ADD CASH" VerticalAlignment="Center" FontWeight="Bold" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding AddPaymentUpiCommand}"
                                Style="{StaticResource OutlinedButtonStyle}" Height="50" Width="140">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Barcode" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center" />
                                <TextBlock Text="ADD UPI" VerticalAlignment="Center" FontWeight="Bold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button Command="{Binding GenerateBillCommand}"
                            IsEnabled="{Binding SelectedInvoice.IsPaid}"
                            Style="{StaticResource PrimaryButtonStyle}" Height="46" Margin="0 8 0 0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocument" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" />
                            <TextBlock Text="GENERATE BILL PREVIEW" VerticalAlignment="Center" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
