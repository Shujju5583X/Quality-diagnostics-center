<UserControl x:Class="LabSystem.UI.Views.Dashboard.NewOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="3.5*" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Patient, Referred By & Summary -->
        <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="1. Patient &amp; Doctor" />

                <!-- Searchable Patient Dropdown -->
                <ComboBox Grid.Row="1"
                          IsEditable="True"
                          materialDesign:HintAssist.Hint="Search and Select Patient *"
                          ItemsSource="{Binding Patients}"
                          SelectedItem="{Binding SelectedPatient}"
                          Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          Margin="0 0 0 16">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding FullName, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text=" (Age: " Foreground="{StaticResource TextSecondaryBrush}" />
                                <Run Text="{Binding AgeDisplay, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <Run Text=", Phone: " Foreground="{StaticResource TextSecondaryBrush}" />
                                <Run Text="{Binding ContactPhone, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <Run Text=")" Foreground="{StaticResource TextSecondaryBrush}" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Referred By Dropdown -->
                <ComboBox Grid.Row="2"
                          materialDesign:HintAssist.Hint="Referred By"
                          ItemsSource="{Binding DoctorsForOrder}"
                          SelectedItem="{Binding SelectedDoctorForOrder}"
                          DisplayMemberPath="FullName"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          Margin="0 0 0 16" />

                <TextBox Grid.Row="3"
                         materialDesign:HintAssist.Hint="Order Notes (optional)"
                         Text="{Binding OrderNotes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                         Margin="0 0 0 16" />

                <!-- Selection Summary Panel -->
                <GroupBox Grid.Row="4" Header="Selection Summary" Margin="0 0 0 16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ListBox Grid.Row="0" ItemsSource="{Binding SelectedTestTypesSummary}" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0 2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat='₹{0:N2}'}"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}" Margin="12,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <!-- Running Total -->
                        <Border Grid.Row="1" Background="{StaticResource PrimaryBackgroundBrush}" CornerRadius="4" Padding="8" Margin="0 8 0 0">
                            <Grid>
                                <TextBlock Text="Total Cost:" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding OrderRunningTotal, StringFormat='₹{0:N2}'}"
                                           FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"
                                           FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>

                <!-- Selected Patient Display -->
                <Border Grid.Row="5" Background="{StaticResource PrimaryBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0 0 0 12">
                    <TextBlock Text="{Binding SelectedPatient.FullName, TargetNullValue='No patient selected'}"
                               FontWeight="Bold" FontSize="13" Foreground="{StaticResource PrimaryDarkBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                </Border>

                <Button Grid.Row="6" Command="{Binding CreateOrderCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="44">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Send" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                        <TextBlock Text="SUBMIT ORDER" VerticalAlignment="Center" FontWeight="Bold" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Right Column: Two-Pane Test Selector -->
        <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Style="{StaticResource ContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" Text="2. Select Tests" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.8*" />
                        <ColumnDefinition Width="2.2*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Pane: Departments & Packages Tabs -->
                    <TabControl Grid.Column="0" Margin="0 0 8 0" BorderThickness="0" Background="Transparent">
                        <TabControl.Resources>
                            <!-- TabControl Style -->
                            <Style TargetType="TabControl">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            
                            <!-- TabItem Style -->
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="16 10" />
                                <Setter Property="Header" Value="{Binding Header, RelativeSource={RelativeSource Self}}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderThickness="0 0 0 3"
                                                    BorderBrush="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter x:Name="ContentSite"
                                                                  ContentSource="Header"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#1000897B" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}" />
                                                    <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource TextDisabledBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!-- ListBoxItem Style (for Left Pane lists) -->
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0 3" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    BorderThickness="1"
                                                    BorderBrush="#E8E8E8"
                                                    Padding="10 8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#F0F7F7" />
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBackgroundBrush}" />
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryDarkBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <TabItem Header="Departments" FontSize="13" FontWeight="SemiBold">
                            <ListBox ItemsSource="{Binding DepartmentsForOrder}" SelectedItem="{Binding SelectedDepartmentForOrder, Mode=TwoWay}" Margin="0 8 0 0" BorderThickness="0" Background="Transparent" FocusVisualStyle="{x:Null}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Margin="0 0 8 0" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="Packages" FontSize="13" FontWeight="SemiBold">
                            <ListBox ItemsSource="{Binding PackagesForOrder}" SelectedItem="{Binding SelectedPackageForOrder, Mode=TwoWay}" Margin="0 8 0 0" BorderThickness="0" Background="Transparent" FocusVisualStyle="{x:Null}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Margin="0 0 8 0" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" Margin="0 0 8 0" />
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="₹" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="13" />
                                                    <TextBlock Text="{Binding Price}" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="13" />
                                                </StackPanel>
                                            </Grid>
                                            <Expander Grid.Row="1" Header="Tests Included" FontSize="11" Margin="24 4 0 0" Padding="0" IsExpanded="False">
                                                <ItemsControl ItemsSource="{Binding TestTypes}" Margin="0 4 0 0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderThickness="0 0 0 1" BorderBrush="#F0F0F0" Padding="0 3">
                                                                <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>

                    <!-- Right Pane: Tests with Search & Filtering -->
                    <Grid Grid.Column="1" Margin="8 0 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search Box & Clear Filters Button -->
                        <Grid Grid.Row="0" Margin="0 0 0 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Search Tests by Name..."
                                     Text="{Binding TestSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     FontSize="13" />

                            <Button Grid.Column="1"
                                    Command="{Binding ClearCategoryFiltersCommand}"
                                    Visibility="{Binding IsCategoryFilterActive, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource ErrorBrush}"
                                    Margin="8 12 0 0"
                                    Height="32"
                                    Padding="8 0"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilterRemove" Margin="0 0 4 0" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="Clear Filter" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Filtered Tests ListBox -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding FilteredTestTypesForOrder}"
                                 BorderThickness="1" BorderBrush="{StaticResource SurfaceBorderBrush}"
                                 Background="#FAFAFA" Padding="4">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0 0 0 1" />
                                    <Setter Property="BorderBrush" Value="#EEEEEE" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        Padding="6 8">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F8FDFD" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Price, StringFormat='₹{0:N2}'}"
                                                   FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" FontSize="12" VerticalAlignment="Center" />

                                        <!-- Ranges below name -->
                                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Text="M: " FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding RefRangeMale}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0 0 8 0" />
                                            <TextBlock Text="F: " FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding RefRangeFemale}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
