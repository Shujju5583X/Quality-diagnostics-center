<Window x:Class="LabSystem.UI.Views.InvoicePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Invoice Preview" Height="600" Width="800" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <WebBrowser x:Name="PdfWebViewer" Grid.Row="0" Margin="10" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Click="Close_Click" Margin="0,0,10,0" Height="40" Padding="16,0" Style="{StaticResource FlatButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                    <TextBlock Text="CLOSE" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
            </Button>
            <Button Click="SavePdf_Click" Margin="0,0,10,0" Height="40" Padding="16,0" Style="{StaticResource OutlinedButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FilePdfBox" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                    <TextBlock Text="SAVE AS PDF" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
            </Button>
            <Button Click="PrintPdf_Click" Height="40" Padding="16,0" Style="{StaticResource PrimaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Printer" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                    <TextBlock Text="PRINT DIRECTLY" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
