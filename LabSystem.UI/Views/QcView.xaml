<UserControl x:Class="LabSystem.UI.Views.QcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:LabSystem.UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <Border Grid.Row="0" Background="#E8EAF6" CornerRadius="8" Padding="16" Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Test Type:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0"/>
                <ComboBox ItemsSource="{Binding TestTypes}" SelectedItem="{Binding SelectedTestType}"
                          DisplayMemberPath="Name" Width="200" Margin="0 0 20 0"
                          Style="{StaticResource MaterialDesignComboBox}"/>

                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="130" Margin="0 0 16 0"/>

                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="130" Margin="0 0 16 0"/>

                <Button Command="{Binding LoadQcRunsCommand}" Content="LOAD" Style="{StaticResource MaterialDesignRaisedButton}" Height="32" Margin="0 0 8 0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- QC Runs DataGrid -->
            <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="16" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="QC RUNS" FontWeight="Bold" FontSize="14" Margin="0 0 0 8" Foreground="#1A237E"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding QcRuns}" AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#FAF9FC" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding RunDate, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
                            <DataGridTextColumn Header="Control" Binding="{Binding ControlName}" Width="*"/>
                            <DataGridTextColumn Header="Measured" Binding="{Binding MeasuredValue, StringFormat='{}{0:N2}'}" Width="80"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetValue, StringFormat='{}{0:N2}'}" Width="80"/>
                            <DataGridTextColumn Header="SD" Binding="{Binding SD, StringFormat='{}{0:N2}'}" Width="60"/>
                            <DataGridTextColumn Header="Lot" Binding="{Binding LotNumber}" Width="80"/>
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8 2" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Reject">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontWeight="Bold" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Status}"/>
                                                        <Setter Property="Foreground" Value="#00796B"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#EF6C00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Reject">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- Record QC Run Form -->
            <materialDesign:Card Grid.Column="1" Padding="16" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="RECORD QC RUN" FontWeight="Bold" FontSize="14" Margin="0 0 0 12" Foreground="#1A237E"/>

                        <TextBox materialDesign:HintAssist.Hint="Control Name *" Text="{Binding ControlName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12"/>

                        <TextBox materialDesign:HintAssist.Hint="Measured Value *" Text="{Binding MeasuredValue, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12"/>

                        <TextBlock Text="Or select a QC Lot:" FontWeight="SemiBold" Margin="0 0 0 4"/>
                        <ComboBox ItemsSource="{Binding QcLots}" SelectedItem="{Binding SelectedLot}"
                                  DisplayMemberPath="LotNumber" Width="200" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignComboBox}" Margin="0 0 0 12"/>

                        <TextBox materialDesign:HintAssist.Hint="Lot Number" Text="{Binding LotNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12"/>
                        <TextBox materialDesign:HintAssist.Hint="Target Value" Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12"/>
                        <TextBox materialDesign:HintAssist.Hint="SD Value" Text="{Binding SdValue, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 16"/>

                        <Button Command="{Binding RecordQcRunCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="42" Margin="0 0 0 16">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                <TextBlock Text="RECORD QC RUN" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <!-- Violations Panel -->
                        <Border Background="#FFF3E0" CornerRadius="6" Padding="12" Margin="0 0 0 8">
                            <StackPanel>
                                <TextBlock Text="VIOLATIONS" FontWeight="Bold" FontSize="12" Foreground="#EF6C00" Margin="0 0 0 8"/>
                                <ItemsControl ItemsSource="{Binding Violations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#C62828" Margin="0 0 0 4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No violations" Foreground="#888" FontStyle="Italic"
                                           Visibility="{Binding Violations.Count, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Status Message -->
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#666" FontStyle="Italic" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
