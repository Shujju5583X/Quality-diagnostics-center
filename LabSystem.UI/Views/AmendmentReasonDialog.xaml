<Window x:Class="LabSystem.UI.Views.AmendmentReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Amendment Reason" Width="400" Height="220" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Enter reason for amending this result:" FontWeight="Bold" FontSize="13" Margin="0 0 0 12"
                   Foreground="{StaticResource TextPrimaryBrush}"/>
        <TextBox Grid.Row="1" x:Name="ReasonTextBox" AcceptsReturn="True" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" MinHeight="60"
                 Style="{StaticResource MaterialDesignTextBox}"
                 materialDesign:HintAssist.Hint="Amendment reason required..."/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
            <Button Content="OK" IsDefault="True" Click="OkButton_Click" Width="80" Height="36" Margin="0 0 8 0"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Cancel" IsCancel="True" Width="80" Height="36"
                    Style="{StaticResource FlatButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
