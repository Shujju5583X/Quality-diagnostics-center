<Window x:Class="LabSystem.UI.Views.PinSetupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Set up PIN" Width="400" SizeToContent="Height" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">
    <StackPanel Margin="32">
        <!-- Header -->
        <TextBlock Text="Welcome!" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"
                   Foreground="{StaticResource PrimaryDarkBrush}"/>
        <TextBlock Text="Please set up a new 4-digit PIN to secure your account." Margin="0,0,0,32" TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="15"/>

        <!-- Form Fields -->
        <PasswordBox x:Name="NewPinBox" Margin="0,0,0,24"
                     PasswordChanged="NewPinBox_PasswordChanged"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     materialDesign:HintAssist.Hint="New PIN"
                     MaxLength="10"/>

        <PasswordBox x:Name="ConfirmPinBox" Margin="0,0,0,8"
                     PasswordChanged="ConfirmPinBox_PasswordChanged"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     materialDesign:HintAssist.Hint="Confirm PIN"
                     MaxLength="10"/>

        <!-- Error Message -->
        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold"
                   Margin="0,8,0,16" TextWrapping="Wrap" MinHeight="20"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringVisibility}}"/>

        <!-- Actions -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save PIN" Command="{Binding SavePinCommand}" 
                    Width="120" Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </StackPanel>
</Window>
