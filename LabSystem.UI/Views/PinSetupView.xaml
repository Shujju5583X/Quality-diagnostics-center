<Window x:Class="LabSystem.UI.Views.PinSetupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Set up PIN" Height="300" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Welcome!" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"
                   Foreground="{StaticResource PrimaryDarkBrush}"/>
        <TextBlock Text="Please set up a new PIN for your account." Margin="0,0,0,20" Grid.Row="1"
                   Foreground="{StaticResource TextSecondaryBrush}"/>

        <TextBlock Text="New PIN:" Grid.Row="2" Margin="0,5,0,5"/>
        <PasswordBox x:Name="NewPinBox" Grid.Row="3" Margin="0,0,0,10"
                     PasswordChanged="NewPinBox_PasswordChanged"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     materialDesign:HintAssist.Hint="Enter 4-digit PIN"
                     MaxLength="10"/>

        <TextBlock Text="Confirm PIN:" Grid.Row="4" Margin="0,5,0,5"/>
        <PasswordBox x:Name="ConfirmPinBox" Grid.Row="5" Margin="0,0,0,10"
                     PasswordChanged="ConfirmPinBox_PasswordChanged"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     materialDesign:HintAssist.Hint="Re-enter PIN"
                     MaxLength="10"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold"
                   Grid.Row="6" Margin="0,10,0,0" TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringVisibility}}"/>

        <Button Content="Save PIN" Command="{Binding SavePinCommand}" Grid.Row="6"
                VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="100" Height="36"
                Style="{StaticResource PrimaryButtonStyle}"/>
    </Grid>
</Window>
