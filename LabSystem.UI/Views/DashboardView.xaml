<UserControl x:Class="LabSystem.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:LabSystem.UI.ViewModels"
             xmlns:views="clr-namespace:LabSystem.UI.Views"
             xmlns:converters="clr-namespace:LabSystem.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366">

    <UserControl.Resources>
        <!-- Sidebar Navigation ListBoxItem Style -->
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="4 4 4 4"/>
            <Setter Property="Padding" Value="0 12"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#25FFFFFF"/>
                                <Setter Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CollectionViewSource x:Key="GroupedTestTypes" Source="{Binding TestTypes}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:DecimalToVisibilityConverter x:Key="DecimalToVis" />

        <!-- Row style: highlight abnormal results in red -->
        <Style x:Key="AbnormalRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#B71C1C"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════ LEFT SIDEBAR NAVIGATION ══════════════ -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Width="60" Background="#1E1926" BorderThickness="0" ClipToBounds="True" MouseEnter="SidebarBorder_MouseEnter" MouseLeave="SidebarBorder_MouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand / Logo & Pin -->
                <Grid Grid.Row="0" Margin="0 20 0 20" Height="50">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Microscope Icon (Centered in the 60px collapsed sidebar) -->
                    <materialDesign:PackIcon Grid.Column="0" Kind="Microscope" Width="32" Height="32" Foreground="#B39DDB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <!-- Brand Text -->
                    <TextBlock Grid.Column="1" Text="QDC SYSTEM" FontSize="14" FontWeight="Bold" Foreground="#9E8FB2" VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <!-- Pin button -->
                    <Button Grid.Column="2" Click="PinButton_Click" Style="{StaticResource MaterialDesignFlatButton}" Padding="4" Width="36" Height="36" Foreground="#9E8FB2" Margin="0 0 10 0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Width="18" Height="18">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="PinOutline"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarPinned}" Value="True">
                                            <Setter Property="Kind" Value="Pin"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                    </Button>
                </Grid>

                <!-- Navigation ListBox synced to MainTabControl -->
                <ListBox Grid.Row="1" 
                          Background="Transparent" 
                          BorderThickness="0"
                          SelectedIndex="{Binding ElementName=MainTabControl, Path=SelectedIndex}"
                          ItemContainerStyle="{StaticResource SidebarItemStyle}">

                    <!-- Tab 0: Overview -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Home" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Overview" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 1: Patients -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="AccountGroup" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Patients" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 2: New Order -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ClipboardText" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="New Order" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 3: Work Queue -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="TestTube" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Work Queue" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 4: Report Generation -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="FileDocumentOutline" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Report Gen" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 5: Billing -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Billing" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 6: Test Catalog -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Database" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Test Catalog" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 7: Doctors -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Account" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Doctors" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 8: Settings -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Cog" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>
                </ListBox>

                <!-- Sidebar Footer -->
                <Border Grid.Row="2" Background="#14111A" Padding="0 14" BorderBrush="#2A2235" BorderThickness="0 1 0 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="AccountCircle" Width="24" Height="24" Foreground="#B39DDB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="8 0 0 0" VerticalAlignment="Center">
                            <TextBlock Text="Lab Technician" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Single Operator Mode" Foreground="#7E7094" FontSize="10" FontWeight="Regular"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════ RIGHT CONTENT AREA ══════════════ -->
        <TabControl x:Name="MainTabControl" Grid.Column="1" BorderThickness="0" Background="#F5F5F7" SelectedIndex="{Binding MainTabIndex}">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ─── TAB 0: OVERVIEW ─── -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Text="System Overview" Margin="4 0 0 20" FontWeight="Bold"/>

                    <!-- Stats Cards -->
                    <Grid Grid.Row="1" Margin="0 0 0 24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lifetime cards -->
                        <materialDesign:Card Grid.Column="0" Margin="4" Padding="20" UniformCornerRadius="8" Background="#EDE7F6" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32" Foreground="#5E35B1" Margin="0 0 0 8"/>
                                <TextBlock Text="TOTAL PATIENTS" FontSize="11" FontWeight="Bold" Foreground="#7E57C2"/>
                                <TextBlock Text="{Binding TotalPatients}" FontSize="36" FontWeight="Bold" Foreground="#311B92" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="1" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFF3E0" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Clock" Width="32" Height="32" Foreground="#EF6C00" Margin="0 0 0 8"/>
                                <TextBlock Text="PENDING ORDERS" FontSize="11" FontWeight="Bold" Foreground="#FB8C00"/>
                                <TextBlock Text="{Binding PendingOrders}" FontSize="36" FontWeight="Bold" Foreground="#E65100" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="2" Margin="4" Padding="20" UniformCornerRadius="8" Background="#E0F2F1" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ClipboardCheck" Width="32" Height="32" Foreground="#00796B" Margin="0 0 0 8"/>
                                <TextBlock Text="COMPLETED" FontSize="11" FontWeight="Bold" Foreground="#26A69A"/>
                                <TextBlock Text="{Binding CompletedOrders}" FontSize="36" FontWeight="Bold" Foreground="#004D40" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="3" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFEBEE" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AlertDecagram" Width="32" Height="32" Foreground="#C62828" Margin="0 0 0 8"/>
                                <TextBlock Text="ABNORMAL FLAGS" FontSize="11" FontWeight="Bold" Foreground="#EF5350"/>
                                <TextBlock Text="{Binding AbnormalResultsFlagged}" FontSize="36" FontWeight="Bold" Foreground="#B71C1C" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Today's cards -->
                        <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="4" Padding="20" UniformCornerRadius="8" Background="#F3E5F5" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountOutline" Width="32" Height="32" Foreground="#7B1FA2" Margin="0 0 0 8"/>
                                <TextBlock Text="TODAY'S PATIENTS" FontSize="11" FontWeight="Bold" Foreground="#9C27B0"/>
                                <TextBlock Text="{Binding TodayPatients}" FontSize="36" FontWeight="Bold" Foreground="#4A148C" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Row="1" Grid.Column="1" Margin="4" Padding="20" UniformCornerRadius="8" Background="#E8F5E9" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="FileDocument" Width="32" Height="32" Foreground="#2E7D32" Margin="0 0 0 8"/>
                                <TextBlock Text="TODAY'S ORDERS" FontSize="11" FontWeight="Bold" Foreground="#43A047"/>
                                <TextBlock Text="{Binding TodayOrders}" FontSize="36" FontWeight="Bold" Foreground="#1B5E20" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Row="1" Grid.Column="2" Margin="4" Padding="20" UniformCornerRadius="8" Background="#E1F5FE" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Cash" Width="32" Height="32" Foreground="#0277BD" Margin="0 0 0 8"/>
                                <TextBlock Text="TODAY'S REVENUE" FontSize="11" FontWeight="Bold" Foreground="#0288D1"/>
                                <TextBlock FontSize="36" FontWeight="Bold" Foreground="#01579B" Margin="0 4 0 0">
                                    <TextBlock.Text>
                                        <Binding Path="TodayRevenue" StringFormat="₹{0:N0}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Row="1" Grid.Column="3" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFF8E1" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Calendar" Width="32" Height="32" Foreground="#F57F17" Margin="0 0 0 8"/>
                                <TextBlock Text="TODAY" FontSize="11" FontWeight="Bold" Foreground="#FFA000"/>
                                <TextBlock Text="{Binding TodayOrders, StringFormat='{}{0} orders'}" FontSize="18" FontWeight="Bold" Foreground="#E65100" Margin="0 4 0 0"/>
                                <TextBlock FontSize="14" Foreground="#BF360C">
                                    <TextBlock.Text>
                                        <Binding Path="TodayPatients" StringFormat="{}{0} patients"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <!-- Recent Orders -->
                    <materialDesign:Card Grid.Row="2" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Text="Recent Test Orders" Margin="4 0 0 12"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="400" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient Name" Binding="{Binding Patient.FullName}" Width="*" />
                                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="Auto" />
                                    <DataGridTextColumn Header="Referred By" Binding="{Binding ReferredBy, TargetNullValue='SELF'}" Width="Auto" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ─── TAB 1: PATIENTS ─── -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3.2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="4 4 4 12" Text="Registered Patients" />

                            <TextBox Grid.Row="1" materialDesign:HintAssist.Hint="Search patient by name, ID, phone..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     Margin="4 0 4 16"
                                     Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                            <WrapPanel Grid.Row="2" Margin="4 0 4 12">
                                <DatePicker materialDesign:HintAssist.Hint="From Reg. Date" SelectedDate="{Binding PatientStartDate}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Width="135" Margin="0 0 12 0" />
                                <DatePicker materialDesign:HintAssist.Hint="To Reg. Date" SelectedDate="{Binding PatientEndDate}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Width="135" />
                            </WrapPanel>

                            <DataGrid Grid.Row="3" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="UHID" Binding="{Binding Uhid}" Width="Auto" />
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender, TargetNullValue='Male'}" Width="Auto" />
                                    <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="Auto" />
                                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactPhone}" Width="Auto" />
                                    <DataGridTemplateColumn Header="Action" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Edit" Command="{Binding DataContext.EditPatientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignFlatButton}" Padding="4" Height="24"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4 8 4 4">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPatientPageCommand}" Content="&lt; Prev" />
                                <TextBlock Text="{Binding PatientPageInfo}" VerticalAlignment="Center" Margin="16 0" FontWeight="SemiBold" />
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPatientPageCommand}" Content="Next &gt;" />
                                <Button Command="{Binding LoadPatientHistoryCommand}" Content="VIEW HISTORY" Margin="16 0 0 0"
                                        Style="{StaticResource MaterialDesignRaisedButton}" Height="32" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="0 0 0 20" Text="{Binding PatientFormTitle}" />

                                <TextBox materialDesign:HintAssist.Hint="Full Name *"
                                         Text="{Binding NewPatientName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
    
                                         Margin="0 0 0 20" />

                                <ComboBox materialDesign:HintAssist.Hint="Gender"
                                          SelectedValue="{Binding NewPatientGender}" SelectedValuePath="Content"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0 0 0 20">
                                    <ComboBoxItem Content="select gender" IsEnabled="False" Visibility="Collapsed"/>
                                    <ComboBoxItem Content="Male" />
                                    <ComboBoxItem Content="Female" />
                                    <ComboBoxItem Content="Others" />
                                </ComboBox>

                                <TextBox materialDesign:HintAssist.Hint="Age *"
                                         Text="{Binding NewPatientAge, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
    
                                         Margin="0 0 0 20" />

                                <TextBox materialDesign:HintAssist.Hint="Contact Phone"
                                         Text="{Binding NewPatientPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
    
                                         Margin="0 0 0 20" />

                                <TextBox materialDesign:HintAssist.Hint="Contact Email"
                                         Text="{Binding NewPatientEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
    
                                         Margin="0 0 0 32" />

                                <Button Command="{Binding AddPatientCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountOutline" Margin="0 0 8 0" VerticalAlignment="Center" Width="20" Height="20" />
                                        <TextBlock Text="{Binding PatientFormButtonText}" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ─── TAB 2: NEW ORDER ─── -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="3.5*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Patient, Referred By & Summary -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="0 0 0 16" Text="1. Patient &amp; Doctor" />

                            <!-- Searchable Patient Dropdown -->
                            <ComboBox Grid.Row="1"
                                      IsEditable="True"
                                      materialDesign:HintAssist.Hint="Search and Select Patient *"
                                      ItemsSource="{Binding Patients}"
                                      SelectedItem="{Binding SelectedPatient}"
                                      Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Margin="0 0 0 16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding FullName, Mode=OneWay}" FontWeight="Bold"/>
                                            <Run Text=" (Age: " Foreground="#777777"/>
                                            <Run Text="{Binding Age, Mode=OneWay}" Foreground="#777777"/>
                                            <Run Text=", Phone: " Foreground="#777777"/>
                                            <Run Text="{Binding ContactPhone, Mode=OneWay}" Foreground="#777777"/>
                                            <Run Text=")" Foreground="#777777"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Referred By Dropdown (Populated from Doctors table + Self) -->
                            <ComboBox Grid.Row="2"
                                      materialDesign:HintAssist.Hint="Referred By"
                                      ItemsSource="{Binding DoctorsForOrder}"
                                      SelectedItem="{Binding SelectedDoctorForOrder}"
                                      DisplayMemberPath="FullName"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Margin="0 0 0 16" />

                            <TextBox Grid.Row="3" materialDesign:HintAssist.Hint="Order Notes (optional)"
                                     Text="{Binding OrderNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                                     Margin="0 0 0 16" />

                            <!-- Selection Summary Panel -->
                            <GroupBox Grid.Row="4" Header="Selection Summary" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Selected Items List -->
                                    <ListBox Grid.Row="0" ItemsSource="{Binding SelectedTestTypesSummary}" BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat='₹{0:N2}'}" FontSize="12" FontWeight="Bold" Foreground="#00796B" Margin="12,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <!-- Running Total -->
                                    <Border Grid.Row="1" Background="#E0F2F1" CornerRadius="4" Padding="8" Margin="0 8 0 0">
                                        <Grid>
                                            <TextBlock Text="Total Cost:" FontWeight="Bold" Foreground="#004D40" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OrderRunningTotal, StringFormat='₹{0:N2}'}" FontWeight="Bold" Foreground="#004D40" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </GroupBox>

                            <!-- Selected Patient Display -->
                            <Border Grid.Row="5" Background="#F1EBF9" CornerRadius="6" Padding="12" Margin="0 0 0 12">
                                <TextBlock Text="{Binding SelectedPatient.FullName, TargetNullValue='No patient selected'}"
                                           FontWeight="Bold" FontSize="13" Foreground="#311B92"
                                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>

                            <Button Grid.Row="6" Command="{Binding CreateOrderCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Send" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                    <TextBlock Text="SUBMIT ORDER" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right Column: Two-Pane Test Selector -->
                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="0 0 0 16" Text="2. Select Tests" />

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="2.2*" />
                                </Grid.ColumnDefinitions>

                                <!-- Left Pane of Selector: Departments & Packages Tabs -->
                                <TabControl Grid.Column="0" Margin="0 0 8 0" BorderThickness="0" Background="Transparent">
                                    <TabItem Header="Departments" FontSize="13" FontWeight="SemiBold">
                                        <ListBox ItemsSource="{Binding DepartmentsForOrder}" SelectedItem="{Binding SelectedDepartmentForOrder, Mode=TwoWay}" Margin="0 8 0 0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0 4">
                                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </TabItem>
                                    <TabItem Header="Packages" FontSize="13" FontWeight="SemiBold">
                                        <ListBox ItemsSource="{Binding PackagesForOrder}" SelectedItem="{Binding SelectedPackageForOrder, Mode=TwoWay}" Margin="0 8 0 0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                                            <TextBlock Text=" - ₹" Foreground="#00796B" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Price}" Foreground="#00796B" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <!-- Collapsed list of tests in package -->
                                                        <Expander Grid.Row="1" Header="Tests List" FontSize="11" Margin="24 2 0 0" Padding="0">
                                                            <ItemsControl ItemsSource="{Binding TestTypes}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Name}" FontSize="11" Margin="4 2" Foreground="#555"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Expander>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </TabItem>
                                </TabControl>

                                <!-- Right Pane of Selector: Tests in selected category -->
                                <ListBox Grid.Column="1" ItemsSource="{Binding FilteredTestTypesForOrder}" BorderThickness="1" BorderBrush="#E0E0E0" Background="#FAFAFA" Padding="4" Margin="8 0 0 0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#EEEEEE" BorderThickness="0 0 0 1" Padding="4 8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" FontSize="12" Foreground="#333" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Price, StringFormat='₹{0:N2}'}" FontWeight="Bold" Foreground="#00796B" FontSize="12" VerticalAlignment="Center"/>
                                                    
                                                    <!-- Ranges below name -->
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0 4 0 0">
                                                        <TextBlock Text="M: " FontSize="10" Foreground="#555"/>
                                                        <TextBlock Text="{Binding RefRangeMale}" FontSize="10" Foreground="#555" Margin="0 0 8 0"/>
                                                        <TextBlock Text="F: " FontSize="10" Foreground="#555"/>
                                                        <TextBlock Text="{Binding RefRangeFemale}" FontSize="10" Foreground="#555"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ─── TAB 3: WORK QUEUE ─── -->
            <TabItem>
                <Grid Margin="12">
                    <TabControl BorderThickness="0" Background="Transparent" SelectedIndex="{Binding WorkQueueTabIndex}">

                        <!-- ═══ SUB-TAB 0: PENDING TESTS ═══ -->
                        <TabItem Header="PENDING TESTS">
                            <materialDesign:Card Padding="0" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#311B92" CornerRadius="8 8 0 0" Padding="16 12">
                                        <StackPanel>
                                            <TextBlock Text="ALL ORDERS" FontWeight="Bold" FontSize="13" Foreground="White"/>
                                            <TextBlock Text="{Binding PendingOrders, StringFormat='({0} pending, tap to enter results)'}" FontSize="11" Foreground="#CE93D8"/>
                                        </StackPanel>
                                    </Border>

                                    <ListView Grid.Row="1" ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}"
                                              SelectionMode="Single" BorderThickness="0" Background="Transparent"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              MouseDoubleClick="PendingTestsList_MouseDoubleClick">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                                <Setter Property="BorderBrush" Value="#EEE"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Background" Value="#FFFDE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                        <Setter Property="Background" Value="#F1F8E9"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#EDE7F6"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="12 10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: Patient Name + Status Badge -->
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Patient.FullName}" FontWeight="Bold" FontSize="13" Foreground="#1A1A2E" TextTrimming="CharacterEllipsis"/>
                                                        <Border Grid.Column="1" CornerRadius="8" Padding="6 2" Margin="4 0 0 0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                            <Setter Property="Background" Value="#FF8F00"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                            <Setter Property="Background" Value="#388E3C"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Row 1: Test Catalog names -->
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 4 0 0">
                                                        <materialDesign:PackIcon Kind="Microscope" Width="12" Height="12" Foreground="#7E57C2" VerticalAlignment="Center" Margin="0 0 4 0"/>
                                                        <TextBlock Text="{Binding TestNamesSummary}" FontSize="11" Foreground="#7E57C2" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- Row 2: Doctor Name -->
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 2 0 0">
                                                        <materialDesign:PackIcon Kind="Account" Width="12" Height="12" Foreground="#888" VerticalAlignment="Center" Margin="0 0 4 0"/>
                                                        <TextBlock Text="{Binding ReferredBy, TargetNullValue='SELF'}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </materialDesign:Card>
                        </TabItem>

                        <!-- ═══ SUB-TAB 1: RESULT ENTRY ═══ -->
                        <TabItem Header="RESULT ENTRY">
                            <materialDesign:Card Padding="0" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header with patient info -->
                                    <Border Grid.Row="0" Background="#1565C0" CornerRadius="8 8 0 0" Padding="16 12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="RESULT ENTRY" FontWeight="Bold" FontSize="13" Foreground="White"/>
                                                <TextBlock Text="{Binding SelectedOrder.Patient.FullName, TargetNullValue='Select an order from PENDING TESTS tab'}"
                                                           FontSize="12" Foreground="#90CAF9" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedOrder.Status, TargetNullValue=''}"
                                                           FontSize="12" Foreground="#FFE082" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding SelectedOrder.OrderedAt, StringFormat={}{0:dd MMM yyyy}}"
                                                           FontSize="11" Foreground="#90CAF9" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Results DataGrid -->
                                    <DataGrid Grid.Row="2"
                                              ItemsSource="{Binding SelectedOrderResults}"
                                              PreviewKeyDown="ResultsEntryGrid_PreviewKeyDown"
                                              AutoGenerateColumns="False"
                                              SelectionMode="Single"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              AlternatingRowBackground="#FAFAFA"
                                              GridLinesVisibility="Horizontal"
                                              RowStyle="{StaticResource AbnormalRowStyle}"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <!-- Test Name (read-only) -->
                                            <DataGridTextColumn Header="Test" Binding="{Binding TestName}" Width="*" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Padding" Value="8 6"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <!-- Result Value — editable TextBox or ComboBox -->
                                            <DataGridTemplateColumn Header="Result Value" Width="160" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsReadOnly="{Binding IsReadOnly}"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"
                                                                     VerticalAlignment="Center"
                                                                     Padding="8 6">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                            <!-- Dropdown for qualitative results -->
                                                            <ComboBox ItemsSource="{Binding Options}"
                                                                      SelectedItem="{Binding SelectedOption}"
                                                                      DisplayMemberPath="Display"
                                                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InvertBool}}"
                                                                      BorderThickness="0"
                                                                      Background="Transparent"
                                                                      VerticalAlignment="Center"
                                                                      Padding="4 2">
                                                                <ComboBox.Style>
                                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasOptions}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ComboBox.Style>
                                                            </ComboBox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Unit -->
                                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Foreground" Value="#666"/>
                                                        <Setter Property="Padding" Value="4 6"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <!-- Reference Range (gender-aware) -->
                                            <DataGridTemplateColumn Header="Ref. Range" Width="180" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4 0">
                                                            <TextBlock Text="{Binding RefRangeDisplay}" FontSize="11" Foreground="#555"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Abnormal Flag -->
                                            <DataGridTemplateColumn Header="Flag" Width="80" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="10" Padding="6 3" HorizontalAlignment="Center" Margin="0 4"
                                                                Visibility="{Binding IsAbnormal, Converter={StaticResource BoolToVis}}">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="#FFCDD2"/>
                                                            </Border.Background>
                                                            <TextBlock Text="ABNORMAL" Foreground="#C62828" FontWeight="Bold" FontSize="10"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Error message -->
                                    <TextBlock Grid.Row="3" Text="{Binding ResultErrorMessage}" Foreground="#C62828"
                                               HorizontalAlignment="Left" Margin="16 6" FontWeight="Medium"
                                               Visibility="{Binding ResultErrorMessage, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Action buttons -->
                                    <Border Grid.Row="4" Background="#F5F5F7" BorderBrush="#E0E0E0" BorderThickness="0 1 0 0" Padding="16 12">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <!-- VERIFY & SAVE (Pending orders only) -->
                                            <Button Command="{Binding SaveResultsCommand}" Margin="0 0 12 0" Height="42">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                                    <TextBlock Text="VERIFY &amp; SAVE" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsResultEditMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Complete">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- EDIT (Complete orders, normal mode) -->
                                            <Button Command="{Binding EditResultsCommand}" Margin="0 0 12 0" Height="42">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Pencil" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                                    <TextBlock Text="EDIT" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Pending">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsResultEditMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- SAVE AMENDMENT (edit mode) -->
                                            <Button Command="{Binding SaveAmendmentCommand}" Margin="0 0 12 0" Height="42"
                                                    Background="#E65100" Foreground="White">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSaveEdit" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                                    <TextBlock Text="SAVE AMENDMENT" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsResultEditMode}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- CANCEL (edit mode) -->
                                            <Button Command="{Binding CancelEditCommand}" Margin="0 0 12 0" Height="42">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Close" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                                    <TextBlock Text="CANCEL" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsResultEditMode}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFlatButton}" Height="42">
                                                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </materialDesign:Card>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- ─── TAB 4: REPORT GENERATION ─── -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*" />
                        <ColumnDefinition Width="3.5*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel: Complete Orders list -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="4 4 4 12" Text="Completed Orders" />

                            <TextBox Grid.Row="1" materialDesign:HintAssist.Hint="Search by patient name, order ID..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"

                                     Margin="4 0 4 16"
                                     Text="{Binding ReportSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                            <DataGrid Grid.Row="2" x:Name="CompletedOrdersGrid" 
                                      ItemsSource="{Binding CompleteOrders}" 
                                      SelectedItem="{Binding SelectedReportOrder, Mode=TwoWay}"
                                      SelectionChanged="CompletedOrdersGrid_SelectionChanged"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient Name" Binding="{Binding Patient.FullName}" Width="*" />
                                    <DataGridTextColumn Header="Completed At" Binding="{Binding UpdatedAt, StringFormat={}{0:dd MMM HH:mm}}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right Panel: Report Preview & Generation -->
                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="4 4 4 12" Text="Report Preview" />

                            <Grid Grid.Row="1" Margin="4 0 4 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" x:Name="ReportLetterheadComboBox"
                                          materialDesign:HintAssist.Hint="Letterhead Option"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          SelectionChanged="ReportLetterheadComboBox_SelectionChanged"
                                          Margin="0 0 12 0" SelectedIndex="0">
                                    <ComboBoxItem Content="With Letterhead" />
                                    <ComboBoxItem Content="Without Letterhead" />
                                </ComboBox>
                                <Button Grid.Column="1" Click="SaveReportPdf_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="36" Margin="0 0 8 0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 4 0" VerticalAlignment="Center" Width="16" Height="16" />
                                        <TextBlock Text="SAVE PDF" VerticalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Click="PrintReportPdf_Click" Style="{StaticResource MaterialDesignRaisedAccentButton}" Height="36">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Printer" Margin="0 0 4 0" VerticalAlignment="Center" Width="16" Height="16" />
                                        <TextBlock Text="PRINT" VerticalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                                <WebBrowser x:Name="ReportWebViewer" Margin="4" />
                            </Border>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            <!-- ─── TAB 5: BILLING ─── -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="4 4 4 12" Text="Invoices" />
                            <DataGrid Grid.Row="1" x:Name="InvoicesGrid" ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Inv #" Binding="{Binding InvoiceId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient" Binding="{Binding Order.Patient.FullName}" Width="*" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}" Width="Auto" />
                                    <DataGridTextColumn Header="Paid" Binding="{Binding AmountPaid, StringFormat='₹{0:N0}'}" Width="Auto" />
                                    <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod, TargetNullValue='-'}" Width="Auto" />
                                    <DataGridTemplateColumn Header="Status" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8 4" HorizontalAlignment="Center" Margin="0 2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                                    <Setter Property="Background" Value="#FFF8E1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                                    <Setter Property="Background" Value="#E0F2F1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontWeight="SemiBold" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                        <Setter Property="Text" Value="Pending"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                                        <Setter Property="Text" Value="Partial"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                                        <Setter Property="Foreground" Value="#00796B"/>
                                                                        <Setter Property="Text" Value="Paid"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F1EBF9" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="36" Height="36" Foreground="#673AB7" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="16 0 0 0">
                                        <TextBlock Text="{Binding SelectedInvoice.Order.Patient.FullName, TargetNullValue='No Invoice Selected'}" FontSize="16" FontWeight="Bold" Foreground="#311B92"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Text="Invoice #" Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedInvoice.InvoiceId, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0"/>
                                            <TextBlock Text="Subtotal: ₹" Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedInvoice.TotalAmount, StringFormat='{}{0:N2}', TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0" Visibility="{Binding SelectedInvoice.DiscountAmount, Converter={StaticResource DecimalToVis}}">
                                            <TextBlock Text="Discount: -₹" Foreground="#C62828" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedInvoice.DiscountAmount, StringFormat='{}{0:N2}'}" FontWeight="Bold" Foreground="#C62828" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0" Visibility="{Binding SelectedInvoice.TaxAmount, Converter={StaticResource DecimalToVis}}">
                                            <TextBlock Text="Tax: +₹" Foreground="#E65100" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedInvoice.TaxAmount, StringFormat='{}{0:N2}'}" FontWeight="Bold" Foreground="#E65100" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Text="Grand Total: ₹" Foreground="#00796B" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedInvoice.GrandTotal, StringFormat='{}{0:N2}', TargetNullValue='-'}" FontWeight="Bold" Foreground="#004D40" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0" Visibility="{Binding SelectedInvoice.DueAmount, Converter={StaticResource DecimalToVis}}">
                                            <TextBlock Text="Due Amount: ₹" Foreground="#C62828" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedInvoice.DueAmount, StringFormat='{}{0:N2}'}" FontWeight="Bold" Foreground="#C62828" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Discount/Tax Section -->
                            <Border Background="#F5F5F5" CornerRadius="8" Padding="12" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="DISCOUNT &amp; TAX" FontSize="11" FontWeight="Bold" Foreground="Gray" Margin="0 0 0 8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Discount (₹):" VerticalAlignment="Center" Width="80" FontSize="12"/>
                                        <TextBox Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="0 0 16 0"
                                                 Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Amount"/>
                                        <TextBlock Text="Tax (₹):" VerticalAlignment="Center" Width="55" FontSize="12"/>
                                        <TextBox Text="{Binding TaxAmount, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="0 0 16 0"
                                                 Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Amount"/>
                                        <Button Command="{Binding ApplyDiscountTaxCommand}" Content="APPLY" Style="{StaticResource MaterialDesignOutlinedButton}" Height="32"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="PAYMENT ACTIONS" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0 0 0 8"/>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                    <TextBlock Text="Amount: ₹" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="8 0 0 0"
                                             Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Enter amount"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 16">
                                    <Button Command="{Binding AddPaymentCashCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Width="140" Margin="0 0 16 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Cash" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="ADD CASH" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding AddPaymentUpiCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Width="140">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Barcode" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="ADD UPI" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Button Command="{Binding GenerateBillCommand}" 
                                        IsEnabled="{Binding SelectedInvoice.IsPaid, FallbackValue=False}"
                                        Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Height="46" Margin="0 8 0 0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileDocument" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="GENERATE BILL PREVIEW" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ─── TAB 6: TEST CATALOG ─── -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" /> <!-- Departments -->
                        <ColumnDefinition Width="*" />   <!-- Tests Grid -->
                        <ColumnDefinition Width="320" /> <!-- Test Edit Form -->
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: Department List -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 8 0" Padding="12" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="0 0 0 12" Text="Departments" />

                            <ListBox Grid.Row="1" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" Margin="0 0 0 12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="2">
                                <TextBox materialDesign:HintAssist.Hint="New Department"
                                         Text="{Binding NewDepartmentName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0 0 0 8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding AddDepartmentCommand}" Content="ADD" Style="{StaticResource MaterialDesignRaisedButton}" Height="32" Margin="0 0 4 0"/>
                                    <Button Grid.Column="1" Command="{Binding RenameDepartmentCommand}" Content="RENAME" Style="{StaticResource MaterialDesignRaisedButton}" Height="32" Margin="4 0 4 0"/>
                                    <Button Grid.Column="2" Command="{Binding DeleteDepartmentCommand}" Content="DELETE" Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Margin="4 0 0 0" Foreground="#C62828" BorderBrush="#C62828"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Column 1: Tests List -->
                    <materialDesign:Card Grid.Column="1" Margin="8 0 8 0" Padding="16" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="0 0 0 8" Text="Tests" />

                            <TextBox Grid.Row="1" x:Name="CatalogSearchBox"
                                     materialDesign:HintAssist.Hint="Search tests..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"

                                     Margin="0 0 0 12"
                                     TextChanged="CatalogSearchBox_TextChanged"/>

                            <DataGrid Grid.Row="2" x:Name="CatalogGrid"
                                      ItemsSource="{Binding CatalogTestTypes}" SelectedItem="{Binding SelectedCatalogTest}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="0" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Test Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='₹{0:N2}'}" Width="Auto" />
                                    <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="Auto" />
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="Auto" />
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Column 2: Test Form -->
                    <materialDesign:Card Grid.Column="2" Margin="8 0 0 0" Padding="16" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignTitleTextBlock}" Margin="0 0 0 16" Text="Manage Test Type" />

                                <TextBox materialDesign:HintAssist.Hint="Test Name *"
                                         Text="{Binding CatalogTestName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                <TextBox materialDesign:HintAssist.Hint="Price (₹) *"
                                         Text="{Binding CatalogTestPrice, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                <Grid Margin="0 0 0 12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Category"
                                             Text="{Binding CatalogTestCategory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 6 0" />
                                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Group Name"
                                             Text="{Binding CatalogTestGroupName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="6 0 0 0" />
                                </Grid>

                                <Grid Margin="0 0 0 12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Unit"
                                             Text="{Binding CatalogTestUnit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 6 0" />
                                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Sort Order"
                                             Text="{Binding CatalogTestSortOrder, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="6 0 0 0" />
                                </Grid>

                                <Grid Margin="0 0 0 12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Ref Range Low"
                                             Text="{Binding CatalogTestLow, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 6 0" />
                                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Ref Range High"
                                             Text="{Binding CatalogTestHigh, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="6 0 0 0" />
                                </Grid>

                                <TextBox materialDesign:HintAssist.Hint="Method (e.g. ELISA)"
                                         Text="{Binding CatalogTestMethod, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                                <TextBox materialDesign:HintAssist.Hint="Interpretation Notes"
                                         Text="{Binding CatalogTestInterpretation, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0 0 0 12" />

                                <CheckBox Content="Is Active Test" IsChecked="{Binding CatalogTestIsActive}" Margin="0 0 0 16" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding SaveCatalogTestCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 4 0" Height="36">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14"/>
                                            <TextBlock Text="SAVE" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Command="{Binding AddCatalogTestCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Margin="2 0 2 0" Height="36">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14"/>
                                            <TextBlock Text="ADD" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Command="{Binding DeleteCatalogTestCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="4 0 0 0" Height="36" Foreground="#C62828">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete" Margin="0 0 2 0" VerticalAlignment="Center" Width="14" Height="14"/>
                                            <TextBlock Text="DEL" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ─── TAB 7: DOCTORS CRUD ─── -->
            <TabItem>
                <Grid Margin="24">
                    <materialDesign:Card Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignTitleTextBlock}" Text="Doctors Registry" Margin="0 0 0 16" FontWeight="Bold"/>

                            <TabControl Grid.Row="1" x:Name="DoctorsTabControl">
                                <!-- Tab A: Details / Form -->
                                <TabItem Header="Doctor Form" FontSize="13" FontWeight="SemiBold">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0 16" MaxWidth="500" HorizontalAlignment="Left">
                                            <TextBlock Style="{StaticResource MaterialDesignTitleTextBlock}" Text="Add / Edit Doctor" Margin="0 0 0 16"/>
                                            
                                            <TextBox materialDesign:HintAssist.Hint="Full Name *"
                                                     Text="{Binding NewDoctorName, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                     Margin="0 0 0 16"/>

                                            <TextBox materialDesign:HintAssist.Hint="Contact Phone *"
                                                     Text="{Binding NewDoctorPhone, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                     Margin="0 0 0 16"/>

                                            <TextBox materialDesign:HintAssist.Hint="Commission Rate (%) *"
                                                     Text="{Binding NewDoctorCommission, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                     Margin="0 0 0 24"/>

                                            <Button Command="{Binding SaveDoctorCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="40">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="SAVE DOCTOR" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- Tab B: Doctors List Grid -->
                                <TabItem Header="Doctors List" FontSize="13" FontWeight="SemiBold">
                                    <Grid Margin="0 16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DataGrid Grid.Row="0" ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                                                  SelectionChanged="DoctorsList_SelectionChanged"
                                                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                                  AlternatingRowBackground="#FAF9FC" EnableRowVirtualization="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Doctor ID" Binding="{Binding DoctorId}" Width="Auto"/>
                                                <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                                <DataGridTextColumn Header="Phone" Binding="{Binding ContactPhone}" Width="Auto"/>
                                                <DataGridTextColumn Header="Commission (%)" Binding="{Binding Commission, StringFormat='{}{0}%'}" Width="Auto"/>
                                                <DataGridTemplateColumn Header="Action" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{Binding DataContext.DeleteDoctorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#C62828" Padding="4" Height="24">
                                                                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ─── TAB 8: SETTINGS / BACKUP ─── -->
            <TabItem>
                <Grid Margin="24" HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="600" Width="500">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MaterialDesignTitleTextBlock}" Text="Settings &amp; Backup" FontWeight="Bold" Margin="0 0 0 24"/>

                        <!-- Operator Info Card -->
                        <materialDesign:Card Padding="24" UniformCornerRadius="8" Margin="0 0 0 20" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignTitleTextBlock}" Text="Operator Identity Settings" Margin="0 0 0 16" FontWeight="SemiBold"/>
                                
                                <TextBox materialDesign:HintAssist.Hint="Laboratory Name *"
                                         Text="{Binding OperatorName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0 0 0 16" />

                                <TextBox materialDesign:HintAssist.Hint="Address *"
                                         Text="{Binding OperatorAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0 0 0 16" />

                                <TextBox materialDesign:HintAssist.Hint="Phone Number *"
                                         Text="{Binding OperatorPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0 0 0 24" />

                                <Button Command="{Binding SaveSettingsCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="40" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18"/>
                                        <TextBlock Text="SAVE SETTINGS" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Database Backup Card -->
                        <materialDesign:Card Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignTitleTextBlock}" Text="CSV Database Backup Engine" Margin="0 0 0 12" FontWeight="SemiBold"/>
                                <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0 0 0 16"
                                           Text="Export full database tables (Patients, Doctors, Invoices, Tests, Results, Settings) to a single CSV backup file. Keep these safe in external storage."/>
                                
                                <Grid Margin="0 0 0 20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Last Backup:" Foreground="Gray" FontWeight="SemiBold" Margin="0 0 12 0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LastBackupTime}" FontWeight="SemiBold" Foreground="#311B92" VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                    <Button Command="{Binding BackupCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Height="42" HorizontalAlignment="Left" Margin="0 0 16 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Database" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                            <TextBlock Text="DOWNLOAD CSV BACKUP" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding RestoreBackupCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="42" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Database" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                            <TextBlock Text="RESTORE FROM CSV" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
