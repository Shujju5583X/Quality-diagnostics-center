<UserControl x:Class="LabSystem.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:LabSystem.UI.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1200">
    <UserControl.Resources>
        <!-- Sidebar Navigation ListBoxItem Style -->
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="10 4 10 4"/>
            <Setter Property="Padding" Value="16 12"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#25FFFFFF"/>
                                <Setter Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <CollectionViewSource x:Key="GroupedTestTypes" Source="{Binding TestTypes}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" Background="#1E1926" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand / Logo -->
                <StackPanel Grid.Row="0" Margin="16 28 16 20">
                    <materialDesign:PackIcon Kind="Microscope" Width="42" Height="42" HorizontalAlignment="Center" Foreground="#B39DDB" Margin="0 0 0 10"/>
                    <TextBlock Text="LAB NAVIGATION" FontSize="11" FontWeight="Bold" Foreground="#9E8FB2" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation ListBox -->
                <ListBox Grid.Row="1" 
                          Background="Transparent" 
                          BorderThickness="0"
                          SelectedIndex="{Binding ElementName=MainTabControl, Path=SelectedIndex}"
                          ItemContainerStyle="{StaticResource SidebarItemStyle}">
                    
                    <!-- Overview -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Home" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Overview" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Patients -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="AccountGroup" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Patients" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>
                    
                    <!-- Create Orders -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ClipboardText" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Create Orders" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>
                    
                    <!-- Results Entry -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="TestTube" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Results Entry" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Specimen Tracking -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="BarcodeScan" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Specimen Tracking" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Quality Control (Phase 4) -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ChartSankeyVariant" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Quality Control" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Patient History (Phase 4) -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ChartLine" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Patient History" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Billing -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Billing" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Test Catalog (Admin only) -->
                    <ListBoxItem Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Database" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Test Catalog" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Audit Logs (Admin only) -->
                    <ListBoxItem Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="History" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Audit Logs" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>
                    
                    <!-- Settings -->
                    <ListBoxItem>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Cog" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>
                </ListBox>

                <!-- Sidebar Footer Account Info -->
                <Border Grid.Row="2" Background="#14111A" Padding="16 14" BorderBrush="#2A2235" BorderThickness="0 1 0 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="AccountCircle" Width="24" Height="24" Foreground="#B39DDB" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="10 0 0 0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentStaffName, TargetNullValue='Technician'}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Staff Account" Foreground="#7E7094" FontSize="10" FontWeight="Regular"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Right Main Content Panels -->
        <TabControl x:Name="MainTabControl" Grid.Column="1" BorderThickness="0" Background="#F5F5F7">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Tab 0: Overview -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Banner -->
                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="System Overview" Margin="4 0 0 20" FontWeight="Bold"/>
                    
                    <!-- Stats Cards -->
                    <Grid Grid.Row="1" Margin="0 0 0 24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Card 1: Patients -->
                        <materialDesign:Card Grid.Column="0" Margin="4" Padding="20" UniformCornerRadius="8" Background="#EDE7F6" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32" Foreground="#5E35B1" Margin="0 0 0 8"/>
                                <TextBlock Text="TOTAL PATIENTS" FontSize="11" FontWeight="Bold" Foreground="#7E57C2"/>
                                <TextBlock Text="{Binding TotalPatients}" FontSize="36" FontWeight="Bold" Foreground="#311B92" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Card 2: Pending Orders -->
                        <materialDesign:Card Grid.Column="1" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFF3E0" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Clock" Width="32" Height="32" Foreground="#EF6C00" Margin="0 0 0 8"/>
                                <TextBlock Text="PENDING ORDERS" FontSize="11" FontWeight="Bold" Foreground="#FB8C00"/>
                                <TextBlock Text="{Binding PendingOrders}" FontSize="36" FontWeight="Bold" Foreground="#E65100" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Card 3: Completed Orders -->
                        <materialDesign:Card Grid.Column="2" Margin="4" Padding="20" UniformCornerRadius="8" Background="#E0F2F1" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ClipboardCheck" Width="32" Height="32" Foreground="#00796B" Margin="0 0 0 8"/>
                                <TextBlock Text="COMPLETED TESTS" FontSize="11" FontWeight="Bold" Foreground="#26A69A"/>
                                <TextBlock Text="{Binding CompletedOrders}" FontSize="36" FontWeight="Bold" Foreground="#004D40" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Card 4: Abnormal Flags -->
                        <materialDesign:Card Grid.Column="3" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFEBEE" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AlertDecagram" Width="32" Height="32" Foreground="#C62828" Margin="0 0 0 8"/>
                                <TextBlock Text="ABNORMAL CASES" FontSize="11" FontWeight="Bold" Foreground="#EF5350"/>
                                <TextBlock Text="{Binding AbnormalResultsFlagged}" FontSize="36" FontWeight="Bold" Foreground="#B71C1C" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                    
                    <!-- Recent Orders List -->
                    <materialDesign:Card Grid.Row="2" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Text="Recent Test Orders" Margin="4 0 0 12"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="400" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient Name" Binding="{Binding Patient.FullName}" Width="*" />
                                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderedAt}" Width="Auto" />
                                    <DataGridTextColumn Header="Referred By" Binding="{Binding ReferredBy, TargetNullValue='SELF'}" Width="Auto" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Tab 1: Patients -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Patients Grid -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Registered Patients" />
                            
                            <!-- Patient Search -->
                            <TextBox Grid.Row="1" 
                                     x:Name="PatientsGridSearchBox"
                                     materialDesign:HintAssist.Hint="Search patient by name, ID, phone..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Margin="4 0 4 16"
                                     Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <!-- Prevent accidental submissions on enter -->
                                </TextBox.InputBindings>
                            </TextBox>

                            <!-- Date Range Filters -->
                            <WrapPanel Grid.Row="2" Margin="4 0 4 12" VerticalAlignment="Center">
                                <DatePicker materialDesign:HintAssist.Hint="From Reg. Date" 
                                            SelectedDate="{Binding PatientStartDate}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                            Width="135" Margin="0 0 12 0" />
                                <DatePicker materialDesign:HintAssist.Hint="To Reg. Date" 
                                            SelectedDate="{Binding PatientEndDate}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                            Width="135" />
                            </WrapPanel>
                            
                            <DataGrid Grid.Row="3" 
                                      x:Name="PatientsGrid" 
                                      ItemsSource="{Binding Patients}" 
                                      SelectedItem="{Binding SelectedPatient}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Single"
                                      Margin="4 0 4 4"
                                      AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding PatientId}" Width="Auto" />
                                    <DataGridTextColumn Header="UHID" Binding="{Binding Uhid}" Width="Auto" />
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender, TargetNullValue='Male'}" Width="Auto" />
                                    <DataGridTextColumn Header="Date of Birth" Binding="{Binding DateOfBirth, StringFormat=yyyy-MM-dd}" Width="Auto" />
                                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactPhone}" Width="Auto" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding ContactEmail}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Pagination Controls -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4 8 4 4">
                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding PreviousPatientPageCommand}"
                                        Content="&lt; Prev" />
                                <TextBlock Text="{Binding PatientPageInfo}" 
                                           VerticalAlignment="Center" 
                                           Margin="16 0" 
                                           FontWeight="SemiBold" />
                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding NextPatientPageCommand}"
                                        Content="Next &gt;" />
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right: Add Patient Card -->
                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 20" Text="Register New Patient" />
                                
                                <TextBox materialDesign:HintAssist.Hint="Full Name" 
                                         Text="{Binding NewPatientName, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Margin="0 0 0 20" />
                                
                                <ComboBox materialDesign:HintAssist.Hint="Gender"
                                          SelectedValue="{Binding NewPatientGender}"
                                          SelectedValuePath="Content"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          Margin="0 0 0 20">
                                    <ComboBoxItem Content="Male" IsSelected="True" />
                                    <ComboBoxItem Content="Female" />
                                    <ComboBoxItem Content="Other" />
                                </ComboBox>

                                <DatePicker materialDesign:HintAssist.Hint="Date of Birth" 
                                            SelectedDate="{Binding NewPatientDOB}" 
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" 
                                            Margin="0 0 0 20" />
                                
                                <TextBox materialDesign:HintAssist.Hint="Contact Phone" 
                                         Text="{Binding NewPatientPhone, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Margin="0 0 0 20" />
                                
                                <TextBox materialDesign:HintAssist.Hint="Contact Email" 
                                         Text="{Binding NewPatientEmail, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Margin="0 0 0 32" />
                                
                                <Button Command="{Binding AddPatientCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountPlus" Margin="0 0 8 0" VerticalAlignment="Center" Width="20" Height="20" />
                                        <TextBlock Text="REGISTER PATIENT" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Tab 2: Orders -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Select Patient -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="1. Select Patient" />
                            
                            <!-- Search -->
                            <TextBox Grid.Row="1"
                                     x:Name="OrderPatientsSearchBox"
                                     materialDesign:HintAssist.Hint="Search patient by name or ID..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Margin="4 0 4 16"
                                     Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                            
                            <DataGrid Grid.Row="2" 
                                      x:Name="OrderPatientsGrid"
                                      ItemsSource="{Binding Patients}" 
                                      SelectedItem="{Binding SelectedPatient}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Single"
                                      Margin="4 0 4 4"
                                      AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding PatientId}" Width="Auto" />
                                    <DataGridTextColumn Header="UHID" Binding="{Binding Uhid}" Width="Auto" />
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Pagination Controls -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4 8 4 4">
                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding PreviousPatientPageCommand}"
                                        Content="&lt; Prev" />
                                <TextBlock Text="{Binding PatientPageInfo}" 
                                           VerticalAlignment="Center" 
                                           Margin="16 0" 
                                           FontWeight="SemiBold" />
                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding NextPatientPageCommand}"
                                        Content="Next &gt;" />
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Middle: Select Tests -->
                    <materialDesign:Card Grid.Column="1" Margin="12 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 16" Text="2. Select Tests" />
                            
                            <ListBox Grid.Row="1" ItemsSource="{Binding Source={StaticResource GroupedTestTypes}}" BorderThickness="0" Background="Transparent" Margin="4 0 4 4"
                                     VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="#EDE7F6" CornerRadius="4" Padding="8 6" Margin="0 8 0 4">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="#5E35B1" />
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="4 10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0 0 12 0" />
                                                
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#333333" VerticalAlignment="Center"/>
                                                
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Ref: " Foreground="#888888" FontSize="12"/>
                                                    <TextBlock Text="{Binding Low}" Foreground="#444444" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text=" - " Foreground="#888888" FontSize="12"/>
                                                    <TextBlock Text="{Binding High}" Foreground="#444444" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text=" " Foreground="#888888" FontSize="12"/>
                                                    <TextBlock Text="{Binding Unit}" Foreground="#888888" FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right: Submit Order -->
                    <materialDesign:Card Grid.Column="2" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 20" Text="3. Confirm Order" />
                            
                            <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0 8 0 0">
                                <materialDesign:PackIcon Kind="ClipboardText" Width="48" Height="48" Foreground="#673AB7" HorizontalAlignment="Center" Margin="0 0 0 16"/>
                                <TextBlock Text="SELECTED PATIENT" FontSize="11" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center" Margin="0 0 0 6"/>
                                
                                <Border Background="#F1EBF9" CornerRadius="6" Padding="12 16" Margin="0 0 0 16">
                                    <TextBlock Text="{Binding SelectedPatient.FullName, TargetNullValue='No patient selected'}" 
                                               FontWeight="Bold" 
                                               FontSize="15" 
                                               Foreground="#311B92"
                                               HorizontalAlignment="Center" 
                                               TextAlignment="Center" 
                                               TextWrapping="Wrap"/>
                                </Border>

                                <ComboBox materialDesign:HintAssist.Hint="Select Test Panel / Package"
                                          ItemsSource="{Binding TestPanels}"
                                          SelectedItem="{Binding SelectedTestPanel}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          Margin="0 0 0 16" />

                                <ComboBox materialDesign:HintAssist.Hint="Select Referring Doctor"
                                          ItemsSource="{Binding Doctors}"
                                          SelectedItem="{Binding SelectedDoctor}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          Margin="0 0 0 16" />
                            </StackPanel>
                            
                            <TextBox Grid.Row="2" materialDesign:HintAssist.Hint="Other Referral Text (if not selected)" 
                                     Text="{Binding OrderReferredBy, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     Margin="0 0 0 24" />

                            <Button Grid.Row="3" Command="{Binding CreateOrderCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Send" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                    <TextBlock Text="SUBMIT ORDER" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Tab 3: Results -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="4*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Orders List -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Orders" />
                            
                            <!-- Search -->
                            <TextBox Grid.Row="1"
                                     x:Name="OrdersSearchBox"
                                     materialDesign:HintAssist.Hint="Search orders by patient, ID, status..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Margin="4 0 4 16"
                                     TextChanged="OrdersSearchBox_TextChanged"/>
                            
                            <DataGrid Grid.Row="2" 
                                      x:Name="OrdersGrid" 
                                      ItemsSource="{Binding Orders}" 
                                      SelectedItem="{Binding SelectedOrder}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Single"
                                      Margin="4 0 4 4"
                                      AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient" Binding="{Binding Patient.FullName}" Width="*" />
                                    
                                    <!-- Custom Badge Style for Order Status -->
                                    <DataGridTemplateColumn Header="Status" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="12" Padding="8 4" HorizontalAlignment="Center" UseLayoutRounding="True" Margin="0 2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                                    <Setter Property="BorderBrush" Value="#FFE0B2"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                    <Setter Property="Background" Value="#E0F2F1"/>
                                                                    <Setter Property="BorderBrush" Value="#B2DFDB"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                        <Setter Property="Foreground" Value="#00796B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right: Results Entry Card -->
                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Patient Summary Banner -->
                            <Border Grid.Row="0" Background="#F1EBF9" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="AccountBox" Width="36" Height="36" Foreground="#673AB7" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="16 0 0 0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedOrder.Patient.FullName, TargetNullValue='No Patient Selected'}" FontSize="16" FontWeight="Bold" Foreground="#311B92"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Text="Order ID: " Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedOrder.OrderId, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0"/>
                                            <TextBlock Text="Ref: " Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedOrder.ReferredBy, TargetNullValue='SELF'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0"/>
                                            <TextBlock Text="Status: " Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedOrder.Status, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedOrderResults}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Margin="0 0 0 8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Test Name" Binding="{Binding TestName}" Width="*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Ref Range" Width="Auto" IsReadOnly="True">
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding StringFormat="{}{0} - {1}">
                                                <Binding Path="Low" TargetNullValue="0" />
                                                <Binding Path="High" TargetNullValue="0" />
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="Auto" IsReadOnly="True" />
                                    
                                    <!-- Value Template supporting Editing and Flagging -->
                                    <DataGridTemplateColumn Header="Value" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <!-- Edit mode (TextBox): Pending + No Options -->
                                                    <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="2 0">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>

                                                    <!-- Edit mode (ComboBox): Pending + Has Options -->
                                                    <ComboBox ItemsSource="{Binding Options}"
                                                              DisplayMemberPath="Display"
                                                              SelectedValuePath="Value"
                                                              SelectedItem="{Binding SelectedOption}"
                                                              Width="120" HorizontalAlignment="Left" Margin="2 0">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignComboBox}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsReadOnly}" Value="False"/>
                                                                            <Condition Binding="{Binding HasOptions}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>

                                                    <!-- Read-only mode: Complete -->
                                                    <StackPanel Orientation="Horizontal" Margin="2 0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding DisplayValue}" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" />
                                                        <Border Background="#FFEBEE" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="4" Padding="6 2" Visibility="Collapsed">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="ABNORMAL" Foreground="#C62828" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Text="{Binding ResultErrorMessage}" Foreground="Red" HorizontalAlignment="Left" Margin="4 8" FontWeight="Medium" />

                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 8 0 0">
                                <!-- Save results button (only for Pending) -->
                                <Button Command="{Binding SaveResultsCommand}" Margin="0 0 12 0" Height="44">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                        <TextBlock Text="VERIFY &amp; SAVE RESULTS" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Complete">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Report generation button (only for Complete) -->
                                <Button Command="{Binding GenerateReportCommand}" Margin="0 0 12 0" Height="44">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FilePdfBox" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                        <TextBlock Text="GENERATE PDF REPORT" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Complete">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Generate Bill button (visible when an order is selected) -->
                                <Button Command="{Binding GenerateBillCommand}" Height="44" Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Receipt" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                        <TextBlock Text="GENERATE BILL" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Amendment Section (only for Complete) -->
                            <materialDesign:Card Grid.Row="4" Margin="0 16 0 0" Padding="16" Background="#FFF3E0">
                                <materialDesign:Card.Style>
                                    <Style TargetType="materialDesign:Card">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Complete">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:Card.Style>
                                <StackPanel>
                                    <TextBlock Text="Amend Result (Enter the Result ID from the database)" FontWeight="Bold" Foreground="#E65100" Margin="0 0 0 8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox materialDesign:HintAssist.Hint="Result ID" Text="{Binding AmendResultId, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0 0 16 0"/>
                                        <TextBox materialDesign:HintAssist.Hint="New Value" Text="{Binding AmendNewValue, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="0 0 16 0"/>
                                        <TextBox materialDesign:HintAssist.Hint="Reason for Amendment" Text="{Binding AmendmentReason, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0 0 16 0"/>
                                        <Button Command="{Binding AmendResultCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Content="SUBMIT AMENDMENT" Foreground="#E65100" BorderBrush="#E65100"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Tab: Specimen Tracking -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="#311B92" Margin="0 0 0 16" Text="Specimen Lifecycle &amp; Barcode Tracking" />

                    <materialDesign:Card Grid.Row="1" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="0" 
                                      ItemsSource="{Binding Specimens}" 
                                      SelectedItem="{Binding SelectedSpecimen}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Single"
                                      Margin="0 0 0 16"
                                      AlternatingRowBackground="#FAF9FC"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Specimen ID" Binding="{Binding SpecimenId}" Width="Auto" />
                                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                                    <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="*" />
                                    <DataGridTextColumn Header="Sample Type" Binding="{Binding SampleType}" Width="*" />
                                    <DataGridTextColumn Header="Collection Time" Binding="{Binding CollectionTime, StringFormat=\{0:dd-MMM-yyyy hh:mm tt\}}" Width="*" />
                                    <DataGridTextColumn Header="Collected By" Binding="{Binding CollectedBy}" Width="*" />
                                    
                                    <DataGridTemplateColumn Header="Status" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8 2" HorizontalAlignment="Center" Margin="0 2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Collected">
                                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                                    <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Received">
                                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                    <Setter Property="Background" Value="#FFF8E1"/>
                                                                    <Setter Property="BorderBrush" Value="#FFE082"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                    <Setter Property="Background" Value="#E0F2F1"/>
                                                                    <Setter Property="BorderBrush" Value="#B2DFDB"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                                    <Setter Property="BorderBrush" Value="#FFCDD2"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Collected">
                                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Received">
                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                        <Setter Property="Foreground" Value="#F57F17"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                        <Setter Property="Foreground" Value="#00796B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTextColumn Header="Rejection Reason" Binding="{Binding RejectionReason}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Transition Status:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0 0 12 0" Foreground="#555555" />
                                <Button Command="{Binding MarkSpecimenReceivedCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Content="MARK RECEIVED" Margin="0 0 12 0" Width="140" Background="#2E7D32" BorderBrush="#2E7D32"/>
                                <Button Command="{Binding MarkSpecimenProcessingCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Content="START PROCESSING" Margin="0 0 12 0" Width="160" Background="#F57F17" BorderBrush="#F57F17"/>
                                <Button Command="{Binding RejectSpecimenCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Content="REJECT SPECIMEN" Width="140" Background="#C62828" BorderBrush="#C62828"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Tab 4: Quality Control -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="#311B92" Margin="0 0 0 16" Text="Quality Control Module" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Add QC Result -->
                        <materialDesign:Card Grid.Column="0" Margin="0 0 16 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 16" Text="Add QC Result" />
                                    
                                    <ComboBox materialDesign:HintAssist.Hint="Select Test Type" 
                                              ItemsSource="{Binding CatalogTestTypes}" 
                                              SelectedItem="{Binding SelectedQcTestType}" 
                                              DisplayMemberPath="Name" 
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}" 
                                              Margin="0 0 0 16" />
                                              
                                    <ComboBox materialDesign:HintAssist.Hint="Control Level"
                                              SelectedValue="{Binding QcControlLevel}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                              Margin="0 0 0 16">
                                        <ComboBoxItem Content="Level 1" IsSelected="True" />
                                        <ComboBoxItem Content="Level 2" />
                                        <ComboBoxItem Content="Level 3" />
                                    </ComboBox>

                                    <TextBox materialDesign:HintAssist.Hint="Expected Mean" 
                                             Text="{Binding QcExpectedMean, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                             Margin="0 0 0 16" />

                                    <TextBox materialDesign:HintAssist.Hint="Standard Deviation (1SD)" 
                                             Text="{Binding QcStandardDeviation, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                             Margin="0 0 0 16" />

                                    <TextBox materialDesign:HintAssist.Hint="Measured Value" 
                                             Text="{Binding QcMeasuredValue, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                             Margin="0 0 0 16" />

                                    <TextBox materialDesign:HintAssist.Hint="Remarks" 
                                             Text="{Binding QcRemarks, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                             Margin="0 0 0 24" />

                                    <Button Command="{Binding SaveQcCommand}" Style="{StaticResource MaterialDesignRaisedButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="SAVE QC RESULT" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:Card>

                        <!-- QC Results Grid -->
                        <materialDesign:Card Grid.Column="1" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Recent QC Runs" />
                                    <Button Command="{Binding RefreshQcCommand}" Style="{StaticResource MaterialDesignFlatButton}" Content="REFRESH" Margin="12 0 0 12"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" 
                                          ItemsSource="{Binding QCResults}" 
                                          AutoGenerateColumns="False" 
                                          IsReadOnly="True" 
                                          SelectionMode="Single"
                                          AlternatingRowBackground="#FAF9FC">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Test Type" Binding="{Binding TestType.Name}" Width="*" />
                                        <DataGridTextColumn Header="Level" Binding="{Binding ControlLevel}" Width="Auto" />
                                        <DataGridTextColumn Header="Mean" Binding="{Binding ExpectedMean}" Width="Auto" />
                                        <DataGridTextColumn Header="Measured" Binding="{Binding MeasuredValue}" Width="Auto" />
                                        
                                        <!-- Status Badge -->
                                        <DataGridTemplateColumn Header="Status" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="8" Padding="6 2" HorizontalAlignment="Center" Margin="0 2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOutOfRange}" Value="False">
                                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                                        <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                                        <Setter Property="BorderBrush" Value="#FFCDD2"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOutOfRange}" Value="False">
                                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                                            <Setter Property="Text" Value="Passed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                                            <Setter Property="Text" Value="Failed (>2SD)"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Date" Binding="{Binding RecordedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 5: Patient History -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="#311B92" Margin="0 0 0 16" Text="Patient Diagnostic History" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Selection -->
                        <materialDesign:Card Grid.Column="0" Margin="0 0 16 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 16" Text="Select Filters" />
                                
                                <ComboBox materialDesign:HintAssist.Hint="Select Patient" 
                                          ItemsSource="{Binding Patients}" 
                                          SelectedItem="{Binding SelectedHistoryPatient}" 
                                          DisplayMemberPath="FullName" 
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" 
                                          Margin="0 0 0 16" />

                                <ComboBox materialDesign:HintAssist.Hint="Select Test Type" 
                                          ItemsSource="{Binding CatalogTestTypes}" 
                                          SelectedItem="{Binding SelectedHistoryTestType}" 
                                          DisplayMemberPath="Name" 
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" 
                                          Margin="0 0 0 16" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Right: LiveCharts Plot -->
                        <materialDesign:Card Grid.Column="1" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 16" Text="Historical Trend" />
                                
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding PatientHistorySeries}" LegendLocation="Right" Background="#FFFFFF">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Date" Labels="{Binding PatientHistoryLabels}" />
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Measured Value" />
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 6: Billing -->
            <TabItem>
                <TabControl BorderThickness="0" Background="Transparent">
                    <TabItem Header="Invoices &amp; Payments" FontSize="14" FontWeight="SemiBold">
                        <Grid Margin="12 24 12 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Invoices List -->
                            <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Invoices" />
                                    
                                    <!-- Search -->
                                    <TextBox Grid.Row="1"
                                             x:Name="InvoicesSearchBox"
                                             materialDesign:HintAssist.Hint="Search invoices by patient, ID..."
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                             materialDesign:TextFieldAssist.HasClearButton="True"
                                             Margin="4 0 4 16"
                                             TextChanged="InvoicesSearchBox_TextChanged"/>
                                    
                                    <DataGrid Grid.Row="2" 
                                              x:Name="InvoicesGrid" 
                                              ItemsSource="{Binding Invoices}" 
                                              SelectedItem="{Binding SelectedInvoice}" 
                                              AutoGenerateColumns="False" 
                                              IsReadOnly="True" 
                                              SelectionMode="Single"
                                              Margin="4 0 4 4"
                                              AlternatingRowBackground="#FAF9FC"
                                              EnableRowVirtualization="True"
                                              VirtualizingStackPanel.IsVirtualizing="True"
                                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Invoice ID" Binding="{Binding InvoiceId}" Width="Auto" />
                                            <DataGridTextColumn Header="Patient" Binding="{Binding Order.Patient.FullName}" Width="*" />
                                            <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount}" Width="Auto" />
                                            
                                            <!-- Custom Badge Style for Invoice Status -->
                                            <DataGridTemplateColumn Header="Status" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="12" Padding="8 4" HorizontalAlignment="Center" UseLayoutRounding="True" Margin="0 2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                                            <Setter Property="BorderBrush" Value="#FFCDD2"/>
                                                                            <Setter Property="BorderThickness" Value="1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                            <Setter Property="Background" Value="#E0F2F1"/>
                                                                            <Setter Property="BorderBrush" Value="#B2DFDB"/>
                                                                            <Setter Property="BorderThickness" Value="1"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontWeight="SemiBold" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                                                <Setter Property="Text" Value="Pending"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                                <Setter Property="Foreground" Value="#00796B"/>
                                                                                <Setter Property="Text" Value="Paid"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </materialDesign:Card>

                            <!-- Right: Invoice Details Card -->
                            <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Summary Banner -->
                                    <Border Grid.Row="0" Background="#F1EBF9" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="36" Height="36" Foreground="#673AB7" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="16 0 0 0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedInvoice.Order.Patient.FullName, TargetNullValue='No Invoice Selected'}" FontSize="16" FontWeight="Bold" Foreground="#311B92"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                                    <TextBlock Text="Invoice ID: " Foreground="#5C6BC0" FontSize="12"/>
                                                    <TextBlock Text="{Binding SelectedInvoice.InvoiceId, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0"/>
                                                    <TextBlock Text="Total: " Foreground="#5C6BC0" FontSize="12"/>
                                                    <TextBlock Text="{Binding SelectedInvoice.TotalAmount, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0"/>
                                                    <TextBlock Text="Status: " Foreground="#5C6BC0" FontSize="12"/>
                                                    <TextBlock Text="{Binding SelectedInvoice.IsPaid, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedInvoice.IsPaid}" Value="False">
                                                                        <Setter Property="Text" Value="Pending"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedInvoice.IsPaid}" Value="True">
                                                                        <Setter Property="Text" Value="Paid"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="0 16">
                                        <TextBlock Text="FINANCIAL ACTIONS" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0 0 0 16"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 12">
                                            <Button Command="{Binding UpdateFinancialsCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="40" Width="296">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="TicketPercent" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="UPDATE DISCOUNT &amp; TAX" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding AddPaymentCashCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Width="140" Margin="0 0 16 0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Cash" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="ADD CASH" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding AddPaymentUpiCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Width="140">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="QrcodeScan" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="ADD UPI" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Referral Analytics" FontSize="14" FontWeight="SemiBold">
                        <Grid Margin="12 24 12 12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Filters -->
                            <materialDesign:Card Grid.Row="0" Padding="16" Margin="0 0 0 16" UniformCornerRadius="6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <DatePicker materialDesign:HintAssist.Hint="Start Date" 
                                                SelectedDate="{Binding ReferralStartDate}" 
                                                Width="150" Margin="0 0 16 0" />
                                    <DatePicker materialDesign:HintAssist.Hint="End Date" 
                                                SelectedDate="{Binding ReferralEndDate}" 
                                                Width="150" Margin="0 0 16 0" />
                                    <Button Command="{Binding RefreshReferralStatsCommand}" 
                                            Style="{StaticResource MaterialDesignRaisedButton}" 
                                            Content="LOAD STATISTICS" Width="160" />
                                </StackPanel>
                            </materialDesign:Card>

                            <!-- Grid -->
                            <materialDesign:Card Grid.Row="1" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <DataGrid ItemsSource="{Binding ReferralStats}" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#FAF9FC">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Doctor Name" Binding="{Binding DoctorName}" Width="*" />
                                        <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="*" />
                                        <DataGridTextColumn Header="Clinic Name" Binding="{Binding ClinicName}" Width="*" />
                                        <DataGridTextColumn Header="Commission (%)" Binding="{Binding CommissionPercent, StringFormat=\{0:N1\}}" Width="Auto" />
                                        <DataGridTextColumn Header="Total Orders" Binding="{Binding TotalOrders}" Width="Auto" />
                                        <DataGridTextColumn Header="Total Revenue (Rs.)" Binding="{Binding TotalRevenue, StringFormat=\{0:F2\}}" Width="Auto" />
                                        <DataGridTextColumn Header="Commission Payable (Rs.)" Binding="{Binding CommissionPayable, StringFormat=\{0:F2\}}" Width="Auto" FontWeight="Bold" Foreground="#2E7D32" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </materialDesign:Card>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Revenue Analytics" FontSize="14" FontWeight="SemiBold">
                        <Grid Margin="12 24 12 12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Filters & Actions -->
                            <materialDesign:Card Grid.Row="0" Padding="16" Margin="0 0 0 16" UniformCornerRadius="6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <DatePicker materialDesign:HintAssist.Hint="Start Date" 
                                                SelectedDate="{Binding ReferralStartDate}" 
                                                Width="150" Margin="0 0 16 0" />
                                    <DatePicker materialDesign:HintAssist.Hint="End Date" 
                                                SelectedDate="{Binding ReferralEndDate}" 
                                                Width="150" Margin="0 0 16 0" />
                                    <Button Command="{Binding RefreshReferralStatsCommand}" 
                                            Style="{StaticResource MaterialDesignRaisedButton}" 
                                            Content="LOAD REVENUE" Width="160" Margin="0 0 16 0" />
                                    <Button Command="{Binding ExportRevenueReportCommand}" 
                                            Style="{StaticResource MaterialDesignRaisedAccentButton}" 
                                            Content="EXPORT TO EXCEL" Width="160" />
                                </StackPanel>
                            </materialDesign:Card>

                            <!-- Summary Cards -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Total Revenue -->
                                <materialDesign:Card Grid.Column="0" Grid.Row="0" Margin="0 0 12 16" Padding="20" UniformCornerRadius="8" Background="#E3F2FD">
                                    <StackPanel>
                                        <TextBlock Text="Total Billed Revenue" Foreground="#1565C0" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding CurrentRevenueReport.TotalRevenue, StringFormat='₹ {0:N2}'}" Foreground="#0D47A1" FontWeight="Bold" FontSize="28" Margin="0 8 0 0" />
                                    </StackPanel>
                                </materialDesign:Card>

                                <!-- Total Collected -->
                                <materialDesign:Card Grid.Column="1" Grid.Row="0" Margin="12 0 12 16" Padding="20" UniformCornerRadius="8" Background="#E8F5E9">
                                    <StackPanel>
                                        <TextBlock Text="Total Collected" Foreground="#2E7D32" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding CurrentRevenueReport.TotalCollected, StringFormat='₹ {0:N2}'}" Foreground="#1B5E20" FontWeight="Bold" FontSize="28" Margin="0 8 0 0" />
                                    </StackPanel>
                                </materialDesign:Card>

                                <!-- Outstanding Amount -->
                                <materialDesign:Card Grid.Column="2" Grid.Row="0" Margin="12 0 0 16" Padding="20" UniformCornerRadius="8" Background="#FFEBEE">
                                    <StackPanel>
                                        <TextBlock Text="Outstanding Balance" Foreground="#C62828" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding CurrentRevenueReport.OutstandingAmount, StringFormat='₹ {0:N2}'}" Foreground="#B71C1C" FontWeight="Bold" FontSize="28" Margin="0 8 0 0" />
                                    </StackPanel>
                                </materialDesign:Card>

                                <!-- Cash vs UPI breakdown -->
                                <materialDesign:Card Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Padding="20" UniformCornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Collection Breakdown" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 16" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0 0 12 0">
                                                <TextBlock Text="Cash Collections" Foreground="Gray" FontSize="14" />
                                                <TextBlock Text="{Binding CurrentRevenueReport.CashCollected, StringFormat='₹ {0:N2}'}" FontWeight="Bold" FontSize="20" Margin="0 4 0 0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="12 0 0 0">
                                                <TextBlock Text="UPI Collections" Foreground="Gray" FontSize="14" />
                                                <TextBlock Text="{Binding CurrentRevenueReport.UpiCollected, StringFormat='₹ {0:N2}'}" FontWeight="Bold" FontSize="20" Margin="0 4 0 0" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </materialDesign:Card>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- Tab 5: Reference Catalog -->
            <TabItem>
                <TabControl BorderThickness="0" Background="Transparent">
                    <TabItem Header="Test Catalog" FontSize="14" FontWeight="SemiBold">
                        <Grid Margin="12 24 12 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <!-- Catalog List Card -->
                            <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Reference Range Catalog" />
                                    
                                    <TextBox Grid.Row="1" 
                                             x:Name="CatalogSearchBox"
                                             materialDesign:HintAssist.Hint="Search catalog by name, category, group..."
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                             materialDesign:TextFieldAssist.HasClearButton="True"
                                             Margin="4 0 4 16"
                                             TextChanged="CatalogSearchBox_TextChanged"/>

                                    <DataGrid Grid.Row="2" 
                                              x:Name="CatalogGrid"
                                              ItemsSource="{Binding CatalogTestTypes}" 
                                              SelectedItem="{Binding SelectedCatalogTest}" 
                                              AutoGenerateColumns="False" 
                                              IsReadOnly="True" 
                                              SelectionMode="Single"
                                              Margin="4 0 4 4"
                                              AlternatingRowBackground="#FAF9FC"
                                              EnableRowVirtualization="True"
                                              VirtualizingStackPanel.IsVirtualizing="True"
                                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding TypeId}" Width="Auto" />
                                            <DataGridTextColumn Header="Test Name" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" />
                                            <DataGridTextColumn Header="Group Name" Binding="{Binding GroupName}" Width="Auto" />
                                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="Auto" />
                                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="Auto" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </materialDesign:Card>

                            <!-- Edit Form Card -->
                            <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 20" Text="Manage Test Type" />

                                        <TextBox materialDesign:HintAssist.Hint="Test Name" 
                                                 Text="{Binding CatalogTestName, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 16" />

                                        <Grid Margin="0 0 0 16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Category (e.g. SEROLOGY)" 
                                                     Text="{Binding CatalogTestCategory, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                     Margin="0 0 8 0" />
                                            <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Group (e.g. Widal Test)" 
                                                     Text="{Binding CatalogTestGroupName, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                     Margin="8 0 0 0" />
                                        </Grid>

                                        <Grid Margin="0 0 0 16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Unit (e.g. g/dL)" 
                                                     Text="{Binding CatalogTestUnit, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                     Margin="0 0 8 0" />
                                            <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Sort Order" 
                                                     Text="{Binding CatalogTestSortOrder, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                     Margin="8 0 0 0" />
                                        </Grid>

                                        <Grid Margin="0 0 0 16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Ref Range Low (Numeric)" 
                                                     Text="{Binding CatalogTestLow, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                     Margin="0 0 8 0" />
                                            <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Ref Range High (Numeric)" 
                                                     Text="{Binding CatalogTestHigh, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                     Margin="8 0 0 0" />
                                        </Grid>

                                        <TextBox materialDesign:HintAssist.Hint="Method (e.g. ELISA)" 
                                                 Text="{Binding CatalogTestMethod, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 16" />

                                        <TextBox materialDesign:HintAssist.Hint="Interpretation Notes" 
                                                 Text="{Binding CatalogTestInterpretation, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="80"
                                                 Margin="0 0 0 16" />

                                        <CheckBox Content="Is Active Test" IsChecked="{Binding CatalogTestIsActive}" Margin="0 0 0 24" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Command="{Binding SaveCatalogTestCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 6 0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" />
                                                    <TextBlock Text="SAVE CHANGES" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Command="{Binding AddCatalogTestCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Margin="6 0 0 0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Plus" Margin="0 0 8 0" VerticalAlignment="Center" />
                                                    <TextBlock Text="ADD NEW" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:Card>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Referring Doctors" FontSize="14" FontWeight="SemiBold">
                        <Grid Margin="12 24 12 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <!-- Doctors Grid -->
                            <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Referring Doctors List" />
                                    
                                    <DataGrid Grid.Row="1" 
                                              ItemsSource="{Binding CatalogDoctors}" 
                                              SelectedItem="{Binding CatalogSelectedDoctor}" 
                                              AutoGenerateColumns="False" 
                                              IsReadOnly="True" 
                                              SelectionMode="Single"
                                              AlternatingRowBackground="#FAF9FC"
                                              EnableRowVirtualization="True"
                                              VirtualizingStackPanel.IsVirtualizing="True"
                                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding DoctorId}" Width="Auto" />
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="*" />
                                            <DataGridTextColumn Header="Clinic Name" Binding="{Binding ClinicName}" Width="*" />
                                            <DataGridTextColumn Header="Phone" Binding="{Binding ContactPhone}" Width="Auto" />
                                            <DataGridTextColumn Header="Commission (%)" Binding="{Binding CommissionPercent, StringFormat=\{0:N1\}}" Width="Auto" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </materialDesign:Card>

                            <!-- CRUD Form -->
                            <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 20" Text="Manage Doctor Profile" />
                                        
                                        <TextBox materialDesign:HintAssist.Hint="Doctor Name" 
                                                 Text="{Binding DocName, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 16" />
                                        
                                        <TextBox materialDesign:HintAssist.Hint="Specialization" 
                                                 Text="{Binding DocSpecialization, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 16" />
                                        
                                        <TextBox materialDesign:HintAssist.Hint="Clinic Name" 
                                                 Text="{Binding DocClinicName, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 16" />
                                        
                                        <TextBox materialDesign:HintAssist.Hint="Contact Phone" 
                                                 Text="{Binding DocContactPhone, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 16" />
                                        
                                        <TextBox materialDesign:HintAssist.Hint="Commission Percent (%)" 
                                                 Text="{Binding DocCommissionPercent, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                                 Margin="0 0 0 24" />
                                                 
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Command="{Binding SaveCatalogDoctorCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 6 0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" />
                                                    <TextBlock Text="SAVE CHANGES" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Command="{Binding AddCatalogDoctorCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Margin="6 0 0 0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Plus" Margin="0 0 8 0" VerticalAlignment="Center" />
                                                    <TextBlock Text="ADD NEW" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:Card>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- Tab 5: Audit Logs -->
            <TabItem>
                <Grid Margin="24">
                    <materialDesign:Card Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="System Audit Logs" />

                            <Grid Grid.Row="1" Margin="4 0 4 16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" 
                                         x:Name="AuditLogSearchBox"
                                         materialDesign:HintAssist.Hint="Search audit logs by action, details, user..."
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         TextChanged="AuditLogSearchBox_TextChanged"/>
                                <Button Grid.Column="1" Command="{Binding RefreshAuditLogsCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="16 0 0 0" Height="40">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Margin="0 0 8 0" VerticalAlignment="Center" />
                                        <TextBlock Text="REFRESH" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <DataGrid Grid.Row="2" 
                                      x:Name="AuditGrid"
                                      ItemsSource="{Binding AuditLogs}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      Margin="4 0 4 4"
                                      AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Log ID" Binding="{Binding LogId}" Width="Auto" />
                                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="Auto" />
                                    <DataGridTextColumn Header="User" Binding="{Binding User.FullName, TargetNullValue='System'}" Width="Auto" />
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="Auto" />
                                    <DataGridTextColumn Header="Entity" Binding="{Binding EntityType}" Width="Auto" />
                                    <DataGridTextColumn Header="Entity ID" Binding="{Binding EntityId}" Width="Auto" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Tab 6: Settings -->
            <TabItem>
                <Grid Margin="24">
                    <materialDesign:Card Padding="40" Width="480" HorizontalAlignment="Center" VerticalAlignment="Center" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="DatabaseSettings" Width="72" Height="72" HorizontalAlignment="Center" Foreground="#673AB7" Margin="0 0 0 20" />
                            <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="System Management" HorizontalAlignment="Center" Margin="0 0 0 10" FontWeight="Bold"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 24">
                                <TextBlock Text="Logged in as: " Foreground="Gray" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentStaffName}" FontWeight="Bold" FontSize="14" Foreground="#311B92"/>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" Text="To secure database integrity, you can trigger a live SQLite database backup. A timestamped copy of your laboratory database will be generated in your project backups directory immediately." 
                                       TextAlignment="Center" Margin="0 0 0 32" Foreground="#666666" LineHeight="20"/>

                            <Button Command="{Binding BackupCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="280" Height="46">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseSync" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                    <TextBlock Text="BACKUP LIVE DATABASE NOW" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
