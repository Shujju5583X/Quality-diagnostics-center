<UserControl x:Class="LabSystem.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:LabSystem.UI.ViewModels"
             xmlns:converters="clr-namespace:LabSystem.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1366">

    <UserControl.Resources>
        <!-- Sidebar Navigation ListBoxItem Style -->
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="10 4 10 4"/>
            <Setter Property="Padding" Value="16 12"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#25FFFFFF"/>
                                <Setter Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CollectionViewSource x:Key="GroupedTestTypes" Source="{Binding TestTypes}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />

        <!-- Row style: highlight abnormal results in red -->
        <Style x:Key="AbnormalRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#B71C1C"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ LEFT SIDEBAR NAVIGATION ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
        <Border Grid.Column="0" Background="#1E1926" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand / Logo -->
                <StackPanel Grid.Row="0" Margin="16 28 16 20">
                    <materialDesign:PackIcon Kind="Microscope" Width="42" Height="42" HorizontalAlignment="Center" Foreground="#B39DDB" Margin="0 0 0 10"/>
                    <TextBlock Text="QDC SYSTEM" FontSize="11" FontWeight="Bold" Foreground="#9E8FB2" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation ListBox synced to MainTabControl -->
                <ListBox Grid.Row="1" 
                         Background="Transparent" 
                         BorderThickness="0"
                         SelectedIndex="{Binding ElementName=MainTabControl, Path=SelectedIndex}"
                         ItemContainerStyle="{StaticResource SidebarItemStyle}">

                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Home" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Overview" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="AccountGroup" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Patients" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ClipboardText" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="New Order" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Tab 3: Work Queue (3-column layout) -->
                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="TestTube" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Work Queue" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Billing" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Database" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Test Catalog" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Cog" Width="22" Height="22" VerticalAlignment="Center" Foreground="#B39DDB"/>
                            <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="8 0 0 0"/>
                        </Grid>
                    </ListBoxItem>
                </ListBox>

                <!-- Sidebar Footer -->
                <Border Grid.Row="2" Background="#14111A" Padding="16 14" BorderBrush="#2A2235" BorderThickness="0 1 0 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="AccountCircle" Width="24" Height="24" Foreground="#B39DDB" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="10 0 0 0" VerticalAlignment="Center">
                            <TextBlock Text="Lab Technician" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Single Operator Mode" Foreground="#7E7094" FontSize="10" FontWeight="Regular"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ RIGHT CONTENT AREA ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
        <TabControl x:Name="MainTabControl" Grid.Column="1" BorderThickness="0" Background="#F5F5F7">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ΓöÇΓöÇΓöÇ TAB 0: OVERVIEW ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="System Overview" Margin="4 0 0 20" FontWeight="Bold"/>

                    <!-- Stats Cards -->
                    <Grid Grid.Row="1" Margin="0 0 0 24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:Card Grid.Column="0" Margin="4" Padding="20" UniformCornerRadius="8" Background="#EDE7F6" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32" Foreground="#5E35B1" Margin="0 0 0 8"/>
                                <TextBlock Text="TOTAL PATIENTS" FontSize="11" FontWeight="Bold" Foreground="#7E57C2"/>
                                <TextBlock Text="{Binding TotalPatients}" FontSize="36" FontWeight="Bold" Foreground="#311B92" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="1" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFF3E0" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Clock" Width="32" Height="32" Foreground="#EF6C00" Margin="0 0 0 8"/>
                                <TextBlock Text="PENDING ORDERS" FontSize="11" FontWeight="Bold" Foreground="#FB8C00"/>
                                <TextBlock Text="{Binding PendingOrders}" FontSize="36" FontWeight="Bold" Foreground="#E65100" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="2" Margin="4" Padding="20" UniformCornerRadius="8" Background="#E0F2F1" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ClipboardCheck" Width="32" Height="32" Foreground="#00796B" Margin="0 0 0 8"/>
                                <TextBlock Text="COMPLETED" FontSize="11" FontWeight="Bold" Foreground="#26A69A"/>
                                <TextBlock Text="{Binding CompletedOrders}" FontSize="36" FontWeight="Bold" Foreground="#004D40" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="3" Margin="4" Padding="20" UniformCornerRadius="8" Background="#FFEBEE" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AlertDecagram" Width="32" Height="32" Foreground="#C62828" Margin="0 0 0 8"/>
                                <TextBlock Text="ABNORMAL FLAGS" FontSize="11" FontWeight="Bold" Foreground="#EF5350"/>
                                <TextBlock Text="{Binding AbnormalResultsFlagged}" FontSize="36" FontWeight="Bold" Foreground="#B71C1C" Margin="0 4 0 0"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <!-- Recent Orders -->
                    <materialDesign:Card Grid.Row="2" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Text="Recent Test Orders" Margin="4 0 0 12"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="400" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient Name" Binding="{Binding Patient.FullName}" Width="*" />
                                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="Auto" />
                                    <DataGridTextColumn Header="Referred By" Binding="{Binding ReferredBy, TargetNullValue='SELF'}" Width="Auto" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ΓöÇΓöÇΓöÇ TAB 1: PATIENTS ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Registered Patients" />

                            <TextBox Grid.Row="1" materialDesign:HintAssist.Hint="Search patient by name, ID, phone..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Margin="4 0 4 16"
                                     Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                            <WrapPanel Grid.Row="2" Margin="4 0 4 12">
                                <DatePicker materialDesign:HintAssist.Hint="From Reg. Date" SelectedDate="{Binding PatientStartDate}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Width="135" Margin="0 0 12 0" />
                                <DatePicker materialDesign:HintAssist.Hint="To Reg. Date" SelectedDate="{Binding PatientEndDate}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Width="135" />
                            </WrapPanel>

                            <DataGrid Grid.Row="3" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="UHID" Binding="{Binding Uhid}" Width="Auto" />
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender, TargetNullValue='Male'}" Width="Auto" />
                                    <DataGridTextColumn Header="Date of Birth" Binding="{Binding DateOfBirth, StringFormat=yyyy-MM-dd}" Width="Auto" />
                                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactPhone}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4 8 4 4">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPatientPageCommand}" Content="&lt; Prev" />
                                <TextBlock Text="{Binding PatientPageInfo}" VerticalAlignment="Center" Margin="16 0" FontWeight="SemiBold" />
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPatientPageCommand}" Content="Next &gt;" />
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 20" Text="Register New Patient" />

                                <TextBox materialDesign:HintAssist.Hint="Full Name *"
                                         Text="{Binding NewPatientName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Margin="0 0 0 20" />

                                <ComboBox materialDesign:HintAssist.Hint="Gender"
                                          SelectedValue="{Binding NewPatientGender}" SelectedValuePath="Content"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0 0 0 20">
                                    <ComboBoxItem Content="Male" IsSelected="True" />
                                    <ComboBoxItem Content="Female" />
                                    <ComboBoxItem Content="Other" />
                                </ComboBox>

                                <DatePicker materialDesign:HintAssist.Hint="Date of Birth"
                                            SelectedDate="{Binding NewPatientDOB}"
                                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                            Margin="0 0 0 20" />

                                <TextBox materialDesign:HintAssist.Hint="Contact Phone"
                                         Text="{Binding NewPatientPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Margin="0 0 0 20" />

                                <TextBox materialDesign:HintAssist.Hint="Contact Email"
                                         Text="{Binding NewPatientEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Margin="0 0 0 32" />

                                <Button Command="{Binding AddPatientCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountPlus" Margin="0 0 8 0" VerticalAlignment="Center" Width="20" Height="20" />
                                        <TextBlock Text="REGISTER PATIENT" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ΓöÇΓöÇΓöÇ TAB 2: NEW ORDER ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <!-- Select Patient -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="1. Select Patient" />

                            <TextBox Grid.Row="1" materialDesign:HintAssist.Hint="Search patient..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Margin="4 0 4 16"
                                     Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                            <DataGrid Grid.Row="2" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="UHID" Binding="{Binding Uhid}" Width="Auto" />
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4 8 4 4">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPatientPageCommand}" Content="&lt; Prev" />
                                <TextBlock Text="{Binding PatientPageInfo}" VerticalAlignment="Center" Margin="16 0" FontWeight="SemiBold" />
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPatientPageCommand}" Content="Next &gt;" />
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Select Tests -->
                    <materialDesign:Card Grid.Column="1" Margin="12 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 16" Text="2. Select Tests" />

                            <ListBox Grid.Row="1" ItemsSource="{Binding Source={StaticResource GroupedTestTypes}}" BorderThickness="0" Background="Transparent" Margin="4 0 4 4"
                                     VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="#EDE7F6" CornerRadius="4" Padding="8 6" Margin="0 8 0 4">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="#5E35B1" />
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="4 10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0 0 12 0" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Low}" Foreground="#444444" FontSize="11"/>
                                                    <TextBlock Text=" ΓÇô " Foreground="#888888" FontSize="11"/>
                                                    <TextBlock Text="{Binding High}" Foreground="#444444" FontSize="11"/>
                                                    <TextBlock Text=" " Foreground="#888888" FontSize="11"/>
                                                    <TextBlock Text="{Binding Unit}" Foreground="#888888" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Confirm Order -->
                    <materialDesign:Card Grid.Column="2" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 16" Text="3. Confirm Order" />

                            <Border Grid.Row="1" Background="#F1EBF9" CornerRadius="6" Padding="12 14" Margin="0 0 0 16">
                                <TextBlock Text="{Binding SelectedPatient.FullName, TargetNullValue='No patient selected'}"
                                           FontWeight="Bold" FontSize="14" Foreground="#311B92"
                                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>

                            <ComboBox Grid.Row="2" materialDesign:HintAssist.Hint="Apply Test Panel / Package"
                                      ItemsSource="{Binding TestPanels}"
                                      SelectedItem="{Binding SelectedTestPanel}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Margin="0 0 0 16" />

                            <!-- ReferredBy ComboBox with editable text for autocomplete -->
                            <ComboBox Grid.Row="3"
                                      IsEditable="True"
                                      materialDesign:HintAssist.Hint="Referred By"
                                      ItemsSource="{Binding ReferredByHistory}"
                                      Text="{Binding OrderReferredBy, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                      Margin="0 0 0 16" />

                            <TextBox Grid.Row="4" materialDesign:HintAssist.Hint="Order Notes (optional)"
                                     Text="{Binding OrderNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" Height="80"
                                     Margin="0 0 0 24" />

                            <Button Grid.Row="5" Command="{Binding CreateOrderCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Send" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                    <TextBlock Text="SUBMIT ORDER" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ΓöÇΓöÇΓöÇ TAB 3: WORK QUEUE (3-COLUMN SINGLE-SCREEN) ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <!-- Column 1: Queue -->
                        <ColumnDefinition Width="280" />
                        <!-- Column 2: Action (Results Entry) -->
                        <ColumnDefinition Width="*" />
                        <!-- Column 3: Output (Actions) -->
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>

                    <!-- ΓòÉΓòÉΓòÉ COLUMN 1: PENDING ORDER QUEUE ΓòÉΓòÉΓòÉ -->
                    <materialDesign:Card Grid.Column="0" Margin="0 0 8 0" Padding="0" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#311B92" CornerRadius="8 8 0 0" Padding="16 12">
                                <StackPanel>
                                    <TextBlock Text="PENDING QUEUE" FontWeight="Bold" FontSize="13" Foreground="White"/>
                                    <TextBlock Text="{Binding PendingOrders, StringFormat='({0} orders awaiting)'}" FontSize="11" Foreground="#CE93D8"/>
                                </StackPanel>
                            </Border>

                            <ListView Grid.Row="1" ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}"
                                      SelectionMode="Single" BorderThickness="0" Background="Transparent"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                        <Setter Property="BorderBrush" Value="#EEE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="#FFFDE7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                <Setter Property="Background" Value="#F1F8E9"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EDE7F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="12 10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Patient.FullName}" FontWeight="Bold" FontSize="13" Foreground="#1A1A2E" TextTrimming="CharacterEllipsis"/>
                                                <!-- Status Badge -->
                                                <Border Grid.Column="1" CornerRadius="8" Padding="6 2" Margin="4 0 0 0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="#FF8F00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                    <Setter Property="Background" Value="#388E3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 3 0 0">
                                                <materialDesign:PackIcon Kind="ClockOutline" Width="12" Height="12" Foreground="#888" VerticalAlignment="Center" Margin="0 0 4 0"/>
                                                <TextBlock Text="{Binding OrderedAt, StringFormat={}{0:dd MMM HH:mm}}" FontSize="11" Foreground="#666"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 2 0 0">
                                                <TextBlock Text="{Binding TestTypes.Count, StringFormat='{}{0} test(s)'}" FontSize="11" Foreground="#7E57C2" FontWeight="SemiBold"/>
                                                <TextBlock Text=" ┬╖ " Foreground="#AAA" FontSize="11"/>
                                                <TextBlock Text="{Binding ReferredBy, TargetNullValue='SELF'}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </materialDesign:Card>

                    <!-- ΓòÉΓòÉΓòÉ COLUMN 2: RESULTS DATA ENTRY GRID ΓòÉΓòÉΓòÉ -->
                    <materialDesign:Card Grid.Column="1" Margin="8 0 8 0" Padding="0" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header with patient info -->
                            <Border Grid.Row="0" Background="#1565C0" CornerRadius="8 8 0 0" Padding="16 12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RESULT ENTRY" FontWeight="Bold" FontSize="13" Foreground="White"/>
                                        <TextBlock Text="{Binding SelectedOrder.Patient.FullName, TargetNullValue='Select an order from the queue ΓåÆ'}"
                                                   FontSize="12" Foreground="#90CAF9" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedOrder.Status, TargetNullValue=''}"
                                                   FontSize="12" Foreground="#FFE082" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding SelectedOrder.OrderedAt, StringFormat={}{0:dd MMM yyyy}}"
                                                   FontSize="11" Foreground="#90CAF9" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Specimen rejection warning -->
                            <Border Grid.Row="1" Background="#FFEBEE" Padding="16 8"
                                    Visibility="{Binding IsSelectedOrderSpecimenRejected, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircle" Width="18" Height="18" Foreground="#C62828" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                    <TextBlock Text="ΓÜá One or more specimens have been REJECTED for this order." Foreground="#C62828" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Results DataGrid -->
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding SelectedOrderResults}"
                                      AutoGenerateColumns="False"
                                      SelectionMode="Single"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      AlternatingRowBackground="#FAFAFA"
                                      GridLinesVisibility="Horizontal"
                                      RowStyle="{StaticResource AbnormalRowStyle}"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <!-- Test Name (read-only) -->
                                    <DataGridTextColumn Header="Test" Binding="{Binding TestName}" Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8 6"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Value ΓÇö editable TextBox or ComboBox depending on HasOptions -->
                                    <DataGridTemplateColumn Header="Result Value" Width="160" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <!-- Text input for numeric results -->
                                                    <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                                             IsReadOnly="{Binding IsReadOnly}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             VerticalAlignment="Center"
                                                             Padding="8 6">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasOptions}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <!-- Dropdown for qualitative results -->
                                                    <ComboBox ItemsSource="{Binding Options}"
                                                              SelectedItem="{Binding SelectedOption}"
                                                              DisplayMemberPath="Display"
                                                              IsEnabled="{Binding IsReadOnly, Converter={StaticResource InvertBool}}"
                                                              BorderThickness="0"
                                                              Background="Transparent"
                                                              VerticalAlignment="Center"
                                                              Padding="4 2">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasOptions}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Unit (read-only) -->
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#666"/>
                                                <Setter Property="Padding" Value="4 6"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Reference Range -->
                                    <DataGridTemplateColumn Header="Ref. Range" Width="120" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4 0">
                                                    <TextBlock Text="{Binding Low}" FontSize="12" Foreground="#555"/>
                                                    <TextBlock Text=" ΓÇô " FontSize="12" Foreground="#AAA"/>
                                                    <TextBlock Text="{Binding High}" FontSize="12" Foreground="#555"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Abnormal Flag badge -->
                                    <DataGridTemplateColumn Header="Flag" Width="80" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="6 3" HorizontalAlignment="Center" Margin="0 4"
                                                        Visibility="{Binding IsAbnormal, Converter={StaticResource BoolToVis}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#FFCDD2"/>
                                                    </Border.Background>
                                                    <TextBlock Text="ABNORMAL" Foreground="#C62828" FontWeight="Bold" FontSize="10"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Error message -->
                            <TextBlock Grid.Row="3" Text="{Binding ResultErrorMessage}" Foreground="#C62828"
                                       HorizontalAlignment="Left" Margin="16 6" FontWeight="Medium"
                                       Visibility="{Binding ResultErrorMessage, Converter={StaticResource BoolToVis}}"/>

                            <!-- Action buttons bottom -->
                            <Border Grid.Row="4" Background="#F5F5F7" BorderBrush="#E0E0E0" BorderThickness="0 1 0 0" Padding="16 12">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding SaveResultsCommand}" Margin="0 0 12 0" Height="42">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                            <TextBlock Text="VERIFY &amp; SAVE" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Complete">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Command="{Binding GenerateReportCommand}" Margin="0 0 12 0" Height="42">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FilePdfBox" Margin="0 0 8 0" VerticalAlignment="Center" Width="18" Height="18" />
                                            <TextBlock Text="REPRINT PDF" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedOrder.Status}" Value="Complete">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFlatButton}" Height="42">
                                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </materialDesign:Card>

                    <!-- ΓòÉΓòÉΓòÉ COLUMN 3: OUTPUT / QUICK ACTIONS ΓòÉΓòÉΓòÉ -->
                    <materialDesign:Card Grid.Column="2" Margin="8 0 0 0" Padding="0" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#4A148C" CornerRadius="8 8 0 0" Padding="16 12">
                                <TextBlock Text="QUICK ACTIONS" FontWeight="Bold" FontSize="13" Foreground="White"/>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <!-- Selected Order Info -->
                                    <Border Background="#F3E5F5" CornerRadius="8" Padding="14" Margin="0 0 0 16">
                                        <StackPanel>
                                            <TextBlock Text="SELECTED ORDER" FontSize="10" FontWeight="Bold" Foreground="#7B1FA2" Margin="0 0 0 6"/>
                                            <TextBlock Text="{Binding SelectedOrder.Patient.FullName, TargetNullValue='None selected'}"
                                                       FontSize="13" FontWeight="Bold" Foreground="#4A148C" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SelectedOrder.OrderId, StringFormat='Order #{0}', TargetNullValue=''}"
                                                       FontSize="11" Foreground="#9C27B0" Margin="0 2 0 0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Divider label -->
                                    <TextBlock Text="REPORTS" FontSize="10" FontWeight="Bold" Foreground="#9E9E9E" Margin="0 0 0 8"/>

                                    <!-- Generate PDF Report -->
                                    <Button Command="{Binding GenerateReportCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#1565C0" BorderBrush="#1565C0"
                                            Height="48" Width="208" HorizontalAlignment="Stretch"
                                            Margin="0 0 0 10">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FilePdfBox" Width="22" Height="22" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Generate Report" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Generate Bill -->
                                    <Button Command="{Binding GenerateBillCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Height="44" HorizontalAlignment="Stretch"
                                            Margin="0 0 0 20">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Receipt" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="View / Print Bill" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Divider label -->
                                    <TextBlock Text="COLLECT PAYMENT" FontSize="10" FontWeight="Bold" Foreground="#9E9E9E" Margin="0 0 0 8"/>

                                    <!-- Invoice Status -->
                                    <Border Margin="0 0 0 12" CornerRadius="6" Padding="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedInvoice.IsPaid}" Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                        <Setter Property="BorderBrush" Value="#FFCDD2"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedInvoice.IsPaid}" Value="True">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedInvoice.TotalAmount, StringFormat='Amount: Γé╣{0:N2}', TargetNullValue='No invoice'}"
                                                       FontWeight="Bold" FontSize="13"/>
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Margin="0 2 0 0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedInvoice.IsPaid}" Value="False">
                                                                <Setter Property="Text" Value="Γ¼ñ UNPAID"/>
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedInvoice.IsPaid}" Value="True">
                                                                <Setter Property="Text" Value="Γ£ö PAID"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Cash Payment Button -->
                                    <Button Command="{Binding AddPaymentCashCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#2E7D32" BorderBrush="#2E7D32"
                                            Height="48" HorizontalAlignment="Stretch"
                                            Margin="0 0 0 10">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Cash" Width="22" Height="22" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="≡ƒÆ╡ Cash Payment" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- UPI Payment Button -->
                                    <Button Command="{Binding AddPaymentUpiCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#E65100" BorderBrush="#E65100"
                                            Height="48" HorizontalAlignment="Stretch"
                                            Margin="0 0 0 20">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="QrcodeScan" Width="22" Height="22" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="≡ƒô▒ UPI Payment" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Divider -->
                                    <Separator Margin="0 0 0 16"/>

                                    <!-- Manual Backup -->
                                    <Button Command="{Binding BackupCommand}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Height="40" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="DatabaseSync" Width="18" Height="18" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Manual Backup" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ΓöÇΓöÇΓöÇ TAB 4: BILLING ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Invoices" />
                            <DataGrid Grid.Row="1" x:Name="InvoicesGrid" ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Inv #" Binding="{Binding InvoiceId}" Width="Auto" />
                                    <DataGridTextColumn Header="Patient" Binding="{Binding Order.Patient.FullName}" Width="*" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='Γé╣{0:N0}'}" Width="Auto" />
                                    <DataGridTemplateColumn Header="Status" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8 4" HorizontalAlignment="Center" Margin="0 2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                    <Setter Property="Background" Value="#E0F2F1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontWeight="SemiBold" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                        <Setter Property="Text" Value="Pending"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                        <Setter Property="Foreground" Value="#00796B"/>
                                                                        <Setter Property="Text" Value="Paid"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F1EBF9" CornerRadius="8" Padding="16" Margin="0 0 0 16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="CashMultiple" Width="36" Height="36" Foreground="#673AB7" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="16 0 0 0">
                                        <TextBlock Text="{Binding SelectedInvoice.Order.Patient.FullName, TargetNullValue='No Invoice Selected'}" FontSize="16" FontWeight="Bold" Foreground="#311B92"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Text="Invoice #" Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedInvoice.InvoiceId, TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12" Margin="0 0 16 0"/>
                                            <TextBlock Text="Total: Γé╣" Foreground="#5C6BC0" FontSize="12"/>
                                            <TextBlock Text="{Binding SelectedInvoice.TotalAmount, StringFormat='{}{0:N2}', TargetNullValue='-'}" FontWeight="Bold" Foreground="#3F51B5" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="PAYMENT ACTIONS" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0 0 0 16"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Command="{Binding AddPaymentCashCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Width="140" Margin="0 0 16 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Cash" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="ADD CASH" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding AddPaymentUpiCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Width="140">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="QrcodeScan" Width="24" Height="24" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="ADD UPI" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ΓöÇΓöÇΓöÇ TAB 5: TEST CATALOG ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4 4 4 12" Text="Reference Range Catalog" />

                            <TextBox Grid.Row="1" x:Name="CatalogSearchBox"
                                     materialDesign:HintAssist.Hint="Search by name, category, group..."
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Margin="4 0 4 16"
                                     TextChanged="CatalogSearchBox_TextChanged"/>

                            <DataGrid Grid.Row="2" x:Name="CatalogGrid"
                                      ItemsSource="{Binding CatalogTestTypes}" SelectedItem="{Binding SelectedCatalogTest}"
                                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      Margin="4 0 4 4" AlternatingRowBackground="#FAF9FC"
                                      EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Test Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" />
                                    <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="Auto" />
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="Auto" />
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 20" Text="Manage Test Type" />

                                <TextBox materialDesign:HintAssist.Hint="Test Name *"
                                         Text="{Binding CatalogTestName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 16" />

                                <Grid Margin="0 0 0 16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Category"
                                             Text="{Binding CatalogTestCategory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 8 0" />
                                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Group Name"
                                             Text="{Binding CatalogTestGroupName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="8 0 0 0" />
                                </Grid>

                                <Grid Margin="0 0 0 16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Unit"
                                             Text="{Binding CatalogTestUnit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 8 0" />
                                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Sort Order"
                                             Text="{Binding CatalogTestSortOrder, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="8 0 0 0" />
                                </Grid>

                                <Grid Margin="0 0 0 16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Ref Range Low"
                                             Text="{Binding CatalogTestLow, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 8 0" />
                                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Ref Range High"
                                             Text="{Binding CatalogTestHigh, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="8 0 0 0" />
                                </Grid>

                                <TextBox materialDesign:HintAssist.Hint="Method (e.g. ELISA)"
                                         Text="{Binding CatalogTestMethod, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 16" />

                                <TextBox materialDesign:HintAssist.Hint="Interpretation Notes"
                                         Text="{Binding CatalogTestInterpretation, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="70" Margin="0 0 0 16" />

                                <CheckBox Content="Is Active Test" IsChecked="{Binding CatalogTestIsActive}" Margin="0 0 0 24" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding SaveCatalogTestCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 6 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0" VerticalAlignment="Center" />
                                            <TextBlock Text="SAVE" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Command="{Binding AddCatalogTestCommand}" Style="{StaticResource MaterialDesignRaisedAccentButton}" Margin="6 0 0 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Margin="0 0 8 0" VerticalAlignment="Center" />
                                            <TextBlock Text="ADD NEW" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- ΓöÇΓöÇΓöÇ TAB 6: SETTINGS / BACKUP ΓöÇΓöÇΓöÇ -->
            <TabItem>
                <Grid Margin="24" HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="600">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="Settings &amp; Backup" FontWeight="Bold" Margin="0 0 0 24"/>

                        <materialDesign:Card Padding="24" UniformCornerRadius="8" Margin="0 0 0 16" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Text="Database Backup" Margin="0 0 0 12"/>
                                <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0 0 0 16"
                                           Text="The system automatically creates an encrypted backup when the application closes. You can also trigger a manual backup at any time."/>
                                <Button Command="{Binding BackupCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="46" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DatabaseSync" Margin="0 0 8 0" VerticalAlignment="Center" Width="20" Height="20" />
                                        <TextBlock Text="BACKUP NOW" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Padding="24" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Text="System Information" Margin="0 0 0 12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode:" Foreground="Gray" Margin="0 0 16 8" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Single Operator (Authentication Disabled)" Margin="0 0 0 8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Patients:" Foreground="Gray" Margin="0 0 16 8" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalPatients}" Margin="0 0 0 8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Pending Orders:" Foreground="Gray" Margin="0 0 16 0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PendingOrders}"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
